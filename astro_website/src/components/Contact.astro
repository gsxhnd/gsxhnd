<!-- Contact Section -->
<section class="contact bg-gray-700" id="contact">
  <div class="contact__container">
    <h2 class="section-title">联系我们</h2>

    <!-- <p class="contact__subtitle">联系我们</p> -->
    <p class="contact__description">
      如有任何疑问、咨询或报价需求，请随时与我们联系。
    </p>
    <ul class="contact__list grid">
      <li>・想委托进行网站和应用程序设计制作</li>
      <li>・正在考虑现有服务的重新设计</li>
      <li>・想咨询项目进行方式和费用感受</li>
      <li>・想咨询技术选型和架构</li>
      <li>・想建立长期合作关系等</li>
    </ul>
    <a href="/contact/" class="contact__cta">联系我们</a>
  </div>
</section>

<style lang="scss">
  .box {
    width: 100px;
    height: 100px;
    background-color: #9911ff;
    border-radius: 10px;
  }
  .contact {
    display: flex;
    &__container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__subtitle {
      text-align: center;
      color: #666;
      margin-bottom: 1rem;
    }

    &__description {
      text-align: center;
      color: #666;
      max-width: 600px;
      margin: 0 auto 1.5rem;
      line-height: 1.6;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        margin: 0 auto 2rem;
      }
    }

    &__list {
      max-width: 600px;
      margin: 0 auto 1.5rem;
      padding: 0;
      list-style: none;
      color: #666;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        margin: 0 auto 2rem;
        font-size: 1rem;
      }

      li {
        margin-bottom: 0.5rem;
        line-height: 1.6;
      }
    }

    &__cta {
      display: block;
      width: fit-content;
      margin: 1.5rem auto 0;
      background: #0066cc;
      color: white;
      padding: 0.8rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.3s;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        margin: 2rem auto 0;
        padding: 1rem 2.5rem;
      }

      &:hover {
        background: #0052a3;
      }
    }
  }
</style>
