---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
---

<Layout title="CName 公司 | 设计体验，创造未来">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__container">
      <h1 class="hero__title">
        设计体验，<br />创造未来
      </h1>
      <p class="hero__subtitle">
        通过设计和技术的力量，挖掘品牌本质，创造新的价值
      </p>
      <a href="#contact" class="hero__cta">联系我们</a>
    </div>
  </section>

  <!-- Partners Section -->
  <section class="partners">
    <div class="partners__container">
      <h2 class="partners__title">与来自各行业的客户建立了合作关系</h2>
      <div class="partners__grid">
        <div class="partner-item">Partner 1</div>
        <div class="partner-item">Partner 2</div>
        <div class="partner-item">Partner 3</div>
        <div class="partner-item">Partner 4</div>
        <div class="partner-item">Partner 5</div>
        <div class="partner-item">Partner 6</div>
        <div class="partner-item">Partner 7</div>
        <div class="partner-item">Partner 8</div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="services__container">
      <h2 class="section-title">服务</h2>
      <div class="services__grid">
        <div class="service-card">
          <div class="service-card__number">01</div>
          <h3>网站与应用开发</h3>
          <p>运用最新技术，构建性能优异、可扩展的 Web 应用程序。</p>
        </div>
        <div class="service-card">
          <div class="service-card__number">02</div>
          <h3>移动应用开发</h3>
          <p>无论原生还是跨平台，为各种设备提供无缝体验的移动解决方案。</p>
        </div>
        <div class="service-card">
          <div class="service-card__number">03</div>
          <h3>UI/UX 设计</h3>
          <p>兼具美感和功能性的以用户为中心的设计，最大化品牌价值。</p>
        </div>
      </div>
      <a href="/services/" class="services__link">查看全部服务</a>
    </div>
  </section>

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <h2 class="section-title">作品集</h2>
      <p class="works__subtitle">作品集</p>
      <div class="works__grid">
        <div class="work-item">
          <div class="work-item__header">
            <span class="work-item__tag">网站与应用开发</span>
            <h3>电商平台重新设计</h3>
          </div>
          <p class="work-item__category">时尚品牌</p>
          <p class="work-item__description">
            对大型时尚零售商的在线商店进行全面改版。通过优化UI/UX，转化率提高40%。
          </p>
          <a href="/works/ec-platform-redesign" class="work-item__link"
            >查看详情</a
          >
        </div>
        <div class="work-item">
          <div class="work-item__header">
            <span class="work-item__tag">UI/UX设计</span>
            <h3>企业品牌建设</h3>
          </div>
          <p class="work-item__category">科技初创公司</p>
          <p class="work-item__description">
            对科技初创公司进行全面品牌更新。进行了标志设计、风格指南和营销资料的制作。
          </p>
          <a href="/works/corporate-branding" class="work-item__link"
            >查看详情</a
          >
        </div>
        <div class="work-item">
          <div class="work-item__header">
            <span class="work-item__tag">移动应用开发</span>
            <h3>移动银行应用</h3>
          </div>
          <p class="work-item__category">金融机构</p>
          <p class="work-item__description">
            拥有10万多活跃用户的安全直观的移动银行应用。提供无缝的交易体验。
          </p>
          <a href="/works/mobile-banking-app" class="work-item__link"
            >查看详情</a
          >
        </div>
        <div class="work-item">
          <div class="work-item__header">
            <span class="work-item__tag">数字战略</span>
            <h3>SaaS仪表板平台</h3>
          </div>
          <p class="work-item__category">企业</p>
          <p class="work-item__description">
            面向企业客户的高级分析仪表板。实现了实时数据可视化和自定义报告功能。
          </p>
          <a href="/works/saas-dashboard-platform" class="work-item__link"
            >查看详情</a
          >
        </div>
      </div>
      <a href="/works/" class="works__link">查看全部作品</a>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <h2 class="section-title">关于我们</h2>
      <p class="about__subtitle">关于我们</p>
      <div class="about__content">
        <p>
          我们通过设计和技术的力量，挖掘品牌本质，创造新的价值。以战略思维和精细的工艺，设计能打动用户心灵的体验，提供加速业务增长的数字解决方案。我们真诚对待每一个项目，与客户一起描绘未来。这就是我们的风格。
        </p>
      </div>
      <a href="/about/" class="about__link">了解更多</a>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <h2 class="section-title">新闻</h2>
      <p class="news__subtitle">新闻</p>
      <div class="news__grid">
        <article class="news-item">
          <time class="news-item__date">2025.1.15</time>
          <span class="news-item__type">新闻</span>
          <h3>
            <a href="/news/2025-01-15-markdown-guide"
              >Markdown 样式指南 - 所有显示元素的示例</a
            >
          </h3>
        </article>
        <article class="news-item">
          <time class="news-item__date">2024.12.15</time>
          <span class="news-item__type">新闻稿</span>
          <h3>
            <a href="/news/2024-12-15-ai-platform-release"
              >发布面向企业的 AI 驱动分析平台</a
            >
          </h3>
        </article>
        <article class="news-item">
          <time class="news-item__date">2024.11.28</time>
          <span class="news-item__type">新闻</span>
          <h3>
            <a href="/news/2024-11-28-team-expansion"
              >五名资深开发者加入团队以加强技术实力</a
            >
          </h3>
        </article>
      </div>
      <a href="/news/" class="news__link">查看全部新闻</a>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 4rem 1.5rem;
    text-align: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
      min-height: 500px;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2rem;
      margin: 0 0 1.5rem 0;
      line-height: 1.3;
      font-weight: 700;

      @media (min-width: 640px) {
        font-size: 2.5rem;
      }

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 1rem;
      margin: 0 0 2rem 0;
      opacity: 0.95;

      @media (min-width: 768px) {
        font-size: 1.2rem;
      }
    }

    &__cta {
      display: inline-block;
      background: white;
      color: #667eea;
      padding: 0.8rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 600;
      transition:
        transform 0.3s,
        box-shadow 0.3s;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        padding: 1rem 2.5rem;
        font-size: 1rem;
      }

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      }
    }
  }

  .partners {
    padding: 3rem 1.5rem;
    background: #f9f9f9;

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      text-align: center;
      font-size: 1.3rem;
      margin: 0 0 2rem 0;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.8rem;
        margin: 0 0 3rem 0;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;

      @media (min-width: 640px) {
        gap: 1.5rem;
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }
    }
  }

  .partner-item {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 8px;
    font-weight: 500;
    color: #666;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .services {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin: 2rem 0;

      @media (min-width: 640px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin: 3rem 0;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      margin-top: 1.5rem;
      transition: color 0.3s;

      @media (min-width: 768px) {
        margin-top: 2rem;
      }

      &:hover {
        color: #0052a3;
      }
    }
  }

  .service-card {
    padding: 1.5rem;
    background: #f5f5f5;
    border-radius: 8px;
    transition:
      transform 0.3s,
      box-shadow 0.3s;

    @media (min-width: 768px) {
      padding: 2rem;
    }

    &:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    &__number {
      font-size: 2rem;
      font-weight: 700;
      color: #0066cc;
      margin-bottom: 1rem;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    h3 {
      font-size: 1.1rem;
      margin: 0 0 1rem 0;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.3rem;
      }
    }

    p {
      margin: 0;
      color: #666;
      font-size: 0.9rem;
      line-height: 1.6;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  .works {
    background: #f9f9f9;
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: #666;
      margin-bottom: 2rem;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: #0052a3;
      }
    }
  }

  .work-item {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    transition: box-shadow 0.3s;

    @media (min-width: 768px) {
      padding: 2rem;
    }

    &:hover {
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    &__header {
      margin-bottom: 1rem;
    }

    &__tag {
      display: inline-block;
      background: #e8f0ff;
      color: #0066cc;
      padding: 0.3rem 0.8rem;
      border-radius: 4px;
      font-size: 0.75rem;
      margin-bottom: 0.5rem;

      @media (min-width: 768px) {
        font-size: 0.8rem;
      }
    }

    h3 {
      margin: 0.5rem 0 0 0;
      font-size: 1rem;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.2rem;
      }
    }

    &__category {
      color: #666;
      font-size: 0.85rem;
      margin: 0.5rem 0;

      @media (min-width: 768px) {
        font-size: 0.9rem;
      }
    }

    &__description {
      color: #666;
      font-size: 0.9rem;
      margin: 1rem 0;
      line-height: 1.6;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__link {
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        font-size: 1rem;
      }

      &:hover {
        color: #0052a3;
      }
    }
  }

  .about {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__subtitle {
      text-align: center;
      color: #666;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        margin-bottom: 2rem;
      }
    }

    &__content {
      max-width: 700px;
      margin: 1.5rem auto;

      @media (min-width: 768px) {
        margin: 2rem auto;
      }

      p {
        font-size: 0.95rem;
        line-height: 1.8;
        color: #666;
        margin: 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      margin-top: 1.5rem;
      transition: color 0.3s;

      @media (min-width: 768px) {
        margin-top: 2rem;
      }

      &:hover {
        color: #0052a3;
      }
    }
  }

  .news {
    background: #f9f9f9;
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: #666;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: #0052a3;
      }
    }
  }

  .news-item {
    background: white;
    padding: 1.2rem;
    border-radius: 8px;
    transition: box-shadow 0.3s;

    @media (min-width: 768px) {
      padding: 1.5rem;
    }

    &:hover {
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    &__date {
      display: block;
      font-size: 0.8rem;
      color: #999;
      margin-bottom: 0.5rem;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      background: #e8f0ff;
      color: #0066cc;
      padding: 0.2rem 0.6rem;
      border-radius: 3px;
      font-size: 0.7rem;
      margin-bottom: 0.5rem;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    h3 {
      margin: 0.5rem 0 0 0;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        font-size: 1rem;
      }

      a {
        color: #333;
        text-decoration: none;
        transition: color 0.3s;

        &:hover {
          color: #0066cc;
        }
      }
    }
  }

  .section-title {
    text-align: center;
    font-size: 1.8rem;
    margin: 0 0 0.5rem 0;
    color: #333;

    @media (min-width: 768px) {
      font-size: 2.5rem;
    }
  }
</style>
