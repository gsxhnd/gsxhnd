---
import Layout from "../layouts/Layout.astro";
---

<Layout title="联系我们 | CName Inc.">
  <section class="contact-hero">
    <div class="contact-hero__container">
      <h1>Contact</h1>
      <p>联系我们</p>
    </div>
  </section>

  <section class="contact-content">
    <div class="contact-content__container">
      <div class="contact-info">
        <h2>关于联系我们</h2>
        <p>
          对于任何困难、咨询、报价请求等，请随时联系我们。以下情况欢迎使用：
        </p>
        <ul class="contact-list">
          <li>想委托设计和制作网站・应用</li>
          <li>正在考虑重新设计现有服务</li>
          <li>想咨询项目进行方式和费用</li>
          <li>想咨询技术选择和架构</li>
          <li>想建立长期的伙伴关系等</li>
        </ul>
      </div>

      <form class="contact-form">
        <div class="form-group">
          <label for="name">公司名・姓名 <span class="required">*</span></label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">电子邮件地址 <span class="required">*</span></label
          >
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="phone">电话号码</label>
          <input type="tel" id="phone" name="phone" />
        </div>

        <div class="form-group">
          <label for="subject">主题 <span class="required">*</span></label>
          <input type="text" id="subject" name="subject" required />
        </div>

        <div class="form-group">
          <label for="message">消息 <span class="required">*</span></label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="form-submit">发送</button>
      </form>

      <div class="contact-details">
        <h2>公司信息</h2>
        <div class="company-info">
          <div class="company-info__item">
            <h3>公司名称</h3>
            <p>CName Inc.</p>
          </div>
          <div class="company-info__item">
            <h3>所在地</h3>
            <p>123</p>
          </div>
          <div class="company-info__item">
            <h3>电话</h3>
            <p><a href="tel:+81-3-xxxx-xxxx">+81-3-XXXX-XXXX</a></p>
          </div>
          <div class="company-info__item">
            <h3>邮件</h3>
            <p><a href="mailto:info@CName.jp">info@CName.jp</a></p>
          </div>
          <div class="company-info__item">
            <h3>营业时间</h3>
            <p>周一至周五 9:00 - 18:00 (周末和假日休息)</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .contact-hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 3rem 1.5rem;
    text-align: center;

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;

      h1 {
        font-size: 2rem;
        margin: 0 0 0.5rem 0;

        @media (min-width: 768px) {
          font-size: 3rem;
        }
      }

      p {
        font-size: 1rem;
        margin: 0;
        opacity: 0.95;

        @media (min-width: 768px) {
          font-size: 1.2rem;
        }
      }
    }
  }

  .contact-content {
    padding: 2.5rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }

    &__container {
      display: grid;
      gap: 2rem;

      @media (min-width: 768px) {
        gap: 3rem;
      }
    }
  }

  .contact-info {
    h2 {
      font-size: 1.3rem;
      margin: 0 0 0.8rem 0;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.8rem;
        margin: 0 0 1rem 0;
      }
    }

    > p {
      color: #666;
      line-height: 1.8;
      margin-bottom: 1rem;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        margin-bottom: 1.5rem;
        font-size: 1rem;
      }
    }
  }

  .contact-list {
    list-style: none;
    padding: 1.5rem;
    margin: 0;
    background: #f5f5f5;
    border-radius: 8px;

    @media (min-width: 768px) {
      padding: 2rem;
    }

    li {
      color: #666;
      margin-bottom: 0.6rem;
      line-height: 1.6;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        margin-bottom: 0.8rem;
        font-size: 1rem;
      }

      &:before {
        content: "・";
        color: #0066cc;
        font-weight: bold;
        margin-right: 0.5rem;
      }

      &:last-child {
        margin-bottom: 0;
      }
    }
  }

  .contact-form {
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;

    @media (min-width: 768px) {
      padding: 2rem;
    }
  }

  .form-group {
    margin-bottom: 1.2rem;

    @media (min-width: 768px) {
      margin-bottom: 1.5rem;
    }

    &:last-child {
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        margin-bottom: 2rem;
      }
    }

    label {
      display: block;
      margin-bottom: 0.4rem;
      font-weight: 600;
      color: #333;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
      }
    }

    input,
    textarea {
      width: 100%;
      padding: 0.6rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 0.9rem;
      font-family: inherit;
      transition: border-color 0.3s;

      @media (min-width: 768px) {
        padding: 0.75rem;
        font-size: 0.95rem;
      }

      &:focus {
        outline: none;
        border-color: #0066cc;
      }
    }

    textarea {
      resize: vertical;
    }
  }

  .required {
    color: #e74c3c;
  }

  .form-submit {
    width: 100%;
    background: #0066cc;
    color: white;
    padding: 0.8rem;
    border: none;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;

    @media (min-width: 768px) {
      padding: 1rem;
      font-size: 1rem;
    }

    &:hover {
      background: #0052a3;
    }

    &:active {
      transform: scale(0.98);
    }
  }

  .contact-details {
    h2 {
      font-size: 1.3rem;
      margin: 0 0 1.5rem 0;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.8rem;
        margin: 0 0 2rem 0;
      }
    }
  }

  .company-info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      gap: 2rem;
    }

    &__item {
      background: #f5f5f5;
      padding: 1.2rem;
      border-radius: 8px;

      @media (min-width: 768px) {
        padding: 1.5rem;
      }

      h3 {
        margin: 0 0 0.5rem 0;
        color: #333;
        font-size: 0.95rem;

        @media (min-width: 768px) {
          font-size: 1rem;
        }
      }

      p {
        margin: 0;
        color: #666;
        line-height: 1.6;
        font-size: 0.9rem;

        @media (min-width: 768px) {
          font-size: 1rem;
        }

        a {
          color: #0066cc;
          text-decoration: none;
          transition: color 0.3s;

          &:hover {
            color: #0052a3;
          }
        }
      }
    }
  }
</style>
