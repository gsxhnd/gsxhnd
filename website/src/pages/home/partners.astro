<style lang="scss">
  .partners {
    padding: 3rem 1.5rem;
    background: #f9f9f9;
    width: 100%;

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }
    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      text-align: center;
      font-size: 1.3rem;
      margin: 0 0 2rem 0;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.8rem;
        margin: 0 0 3rem 0;
      }
    }

    .slider-container {
      width: 100%;
      .slider-tracker {
        display: flex;
        //   grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        animation: scroll 2s linear infinite;
        width: fit-content;
        mask-image: linear-gradient(
          to right,
          transparent,
          black 10%,
          black 90%,
          transparent
        );
        @keyframes scroll {
          0% {
            transform: translate(20%);
          }

          to {
            transform: translate(0%);
          }
        }
      }
    }
  }

  .partner-item {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 8px;
    font-weight: 500;
    color: #666;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
