---
interface Props {
  tag: string;
  title: string;
  category: string;
  description: string;
  link: string;
}

const { tag, title, category, description, link } = Astro.props;
---

<div class="work-item">
  <div class="work-item__header">
    <span class="work-item__tag">{tag}</span>
    <h3>{title}</h3>
  </div>
  <p class="work-item__category">{category}</p>
  <p class="work-item__description">
    {description}
  </p>
  <a href={link} class="work-item__link">查看详情</a>
</div>

<style lang="scss">
  .work-item {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;

    @media (min-width: 768px) {
      padding: 2rem;
    }

    &:hover {
      border-color: #667eea;
      box-shadow: 0 8px 24px rgba(102, 126, 234, 0.12);
      transform: translateY(-4px);
    }

    &__header {
      margin-bottom: 1rem;
    }

    &__tag {
      display: inline-block;
      background: #e8f0ff;
      color: #0066cc;
      padding: 0.3rem 0.8rem;
      border-radius: 4px;
      font-size: 0.75rem;
      margin-bottom: 0.5rem;
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.8rem;
      }
    }

    h3 {
      margin: 0.5rem 0 0 0;
      font-size: 1rem;
      color: #333;

      @media (min-width: 768px) {
        font-size: 1.2rem;
      }
    }

    &__category {
      color: #666;
      font-size: 0.85rem;
      margin: 0.5rem 0;

      @media (min-width: 768px) {
        font-size: 0.9rem;
      }
    }

    &__description {
      color: #666;
      font-size: 0.9rem;
      line-height: 1.6;
      margin: 0.5rem 0 1rem;
      flex-grow: 1;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__link {
      color: #0066cc;
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      align-self: flex-start;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }

      &:hover {
        color: #764ba2;
        text-decoration: underline;
      }
    }
  }
</style>
