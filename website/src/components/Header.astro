---
import { Image } from "astro:assets";
import logoImage from "../assets/astro.svg";
import "../styles/global.css";
---

<header class="header">
  <div class="header__container">
    <div class="header__logo">
      <a href="/">
        <Image src={logoImage} alt="CName" />
      </a>
    </div>
    <nav class="header__nav">
      <ul class="header__nav-list">
        <li>
          <a href="/services">服务</a>
        </li>
        <li>
          <a href="/works">作品</a>
        </li>
        <li>
          <a href="/news">新闻</a>
        </li>
        <li>
          <a href="/about">关于</a>
        </li>
        <li>
          <a href="/contact" class="header__nav-cta">联系我们</a>
        </li>
      </ul>
    </nav>
    <button class="header__mobile-toggle" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style lang="scss">
  .header {
    background: #fff;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 100;

    &__container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      justify-content: space-between;

      @media (min-width: 768px) {
        padding: 1rem 2rem;
      }
    }

    &__logo {
      font-size: 1.2rem;
      font-weight: 700;
      flex-shrink: 0;

      @media (min-width: 768px) {
        font-size: 1.5rem;
      }

      a {
        text-decoration: none;
        color: #333;
        transition: opacity 0.3s;
        display: flex;
        align-items: center;

        &:hover {
          opacity: 0.7;
        }
      }
    }

    &__nav {
      flex: 1;
      display: none;

      @media (min-width: 768px) {
        display: block;
      }
    }

    &__nav-list {
      list-style: none;
      display: flex;
      gap: 1rem;
      margin: 0;
      padding: 0;
      justify-content: flex-end;
      align-items: center;
      flex-wrap: wrap;

      @media (min-width: 1024px) {
        gap: 2rem;
      }

      a {
        text-decoration: none;
        color: #333;
        font-size: 0.85rem;
        transition: color 0.3s;
        white-space: nowrap;

        @media (min-width: 768px) {
          font-size: 0.95rem;
        }

        &:hover {
          color: #0066cc;
        }
      }
    }

    &__nav-cta {
      background: #0066cc !important;
      color: #fff !important;
      padding: 0.4rem 1rem !important;
      border-radius: 4px;
      font-size: 0.85rem !important;
      transition: background 0.3s;

      @media (min-width: 768px) {
        padding: 0.5rem 1.5rem !important;
      }

      &:hover {
        background: #0052a3 !important;
      }
    }

    &__mobile-toggle {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      margin-right: -0.5rem;

      @media (min-width: 768px) {
        display: none;
      }

      span {
        width: 1.5rem;
        height: 2px;
        background: #333;
        transition: all 0.3s ease;
        display: block;
      }

      &:hover span {
        background: #0066cc;
      }
    }
  }
</style>
