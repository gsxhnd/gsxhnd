---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}

const { title = "CName 公司 | 设计体验，创造未来" } = Astro.props;
---

<!doctype html>
<html lang="zh" style="--headerHeight: 74px; --headerHeightMobile: 60px;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#222828" />
    <title>{title}</title>
    <meta
      name="description"
      content="通过设计和技术的力量，挖掘品牌本质，创造新的价值"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body style="--headerHeight: 74px; --headerHeightMobile: 60px;">
    <Header />
    <main class="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-padding-top: var(--headerHeightMobile);
  }

  @media (min-width: 900px) {
    html {
      scroll-padding-top: var(--headerHeight);
    }
  }

  .main {
    min-height: calc(100vh - 200px);
  }
</style>
