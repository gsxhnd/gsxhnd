---
interface Props {
  href?: string;
  variant?: 'solid' | 'solid-sub' | 'outlined';
  size?: 'small' | 'medium' | 'large';
  class?: string;
  [key: string]: any;
}

const { 
  href, 
  variant = 'solid', 
  size = 'medium', 
  class: className = '',
  ...rest 
} = Astro.props;

const Element = href ? 'a' : 'button';
---

<Element 
  href={href}
  class={`button -${variant} -${size} ${className}`}
  {...rest}
>
  <slot />
</Element>

<style>
  .button {
    position: relative;
    display: inline-block;
    width: var(--buttonWidth, auto);
    padding: var(--sp-md) var(--sp-xl);
    border-radius: var(--radius-full);
    border-width: 2px;
    border-style: solid;
    background-size: 200% 100%;
    background-position: right;
    font-size: var(--fs-base);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background-position var(--transition-slow),
                color var(--transition-slow),
                border-color var(--transition-slow);
  }

  .button:is(:hover, :focus-within) {
    background-position: left;
  }

  .button.-small {
    font-size: var(--fs-base);
    padding: var(--sp-xs) var(--sp-lg);
  }

  .button.-medium {
    padding: var(--sp-sm) var(--sp-xl);
  }

  .button.-large {
    padding: calc(var(--sp-xs) * 3) var(--sp-2xl);
  }

  .button.-solid {
    color: var(--c-text-inverse);
    background-image: linear-gradient(
      to right,
      var(--c-bg) 50%,
      var(--c-primary) 50%
    );
    border-color: var(--c-primary);
  }

  .button.-solid:is(:hover, :focus-within) {
    color: var(--c-text);
    border-color: var(--c-primary);
  }

  .button.-solid-sub {
    color: var(--c-text);
    background-image: linear-gradient(
      to right,
      var(--c-primary) 50%,
      var(--c-bg) 50%
    );
    border-color: var(--c-bg);
  }

  .button.-solid-sub:is(:hover, :focus-within) {
    color: var(--c-text-inverse);
    border-color: var(--c-bg);
  }

  .button.-outlined {
    color: var(--c-text);
    background-image: linear-gradient(
      to right,
      var(--c-primary) 50%,
      transparent 50%
    );
    border-color: var(--c-border);
  }

  .button.-outlined:is(:hover, :focus-within) {
    color: var(--c-text-inverse);
    border-color: var(--c-primary);
  }
</style>
