---
interface Props {
  date: string;
  type: string;
  title: string;
  link: string;
}

const { date, type, title, link } = Astro.props;
---

<article class="news-item">
  <time class="news-item__date">{date}</time>
  <span class="news-item__type">{type}</span>
  <h3>
    <a href={link}>
      {title}
    </a>
  </h3>
</article>

<style lang="scss">
  .news-item {
    padding: 1.5rem;
    background: white;
    border-radius: 8px;
    border-left: 4px solid var(--c-primary);
    transition: all 0.3s ease;

    @media (min-width: 768px) {
      padding: 2rem;
    }

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
      border-left-color: #764ba2;
    }

    &__date {
      display: block;
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin-bottom: 0.5rem;
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.9rem;
      }
    }

    &__type {
      display: inline-block;
      background: #eff2ff;
      color: var(--c-primary);
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      font-size: 0.75rem;
      margin-bottom: 0.8rem;
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.8rem;
        padding: 0.3rem 0.8rem;
      }
    }

    h3 {
      margin: 0;
      font-size: 1rem;

      @media (min-width: 768px) {
        font-size: 1.1rem;
      }

      a {
        color: var(--c-text);
        text-decoration: none;
        transition: color 0.3s ease;

        &:hover {
          color: var(--c-primary);
          text-decoration: underline;
        }
      }
    }
  }
</style>
