---
interface Props {
  date: string;
  type: string;
  title: string;
  link: string;
}

const { date, type, title, link } = Astro.props;
---

<a href={link} class="news-item">
  <time class="news-item__date">{date}</time>
  <span class="news-item__type">{type}</span>
  <span class="news-item__title">{title}</span>
</a>

<style lang="scss">
  .news-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    @media (min-width: 768px) {
      grid-template-columns: 110px 100px 1fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 0;
    }

    &:hover {
      opacity: 0.6;
    }

    &__date {
      font-size: 0.8rem;
      color: var(--c-text-light);
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      font-weight: 500;
      width: fit-content;
      white-space: nowrap;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    &__title {
      font-size: 0.9rem;
      color: var(--c-text);
      font-weight: 400;
      line-height: 1.5;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }
</style>
