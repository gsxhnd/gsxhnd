---
import Container from './Container.astro';
import Logo from './Logo.astro';
import Button from './Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { SITE_CONFIG } from '../config/site';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="header" id="header">
  <Container size="large">
    <div class="header-inner">
      <Logo class="header-logo" />
      
      <button class="menu-button" aria-label="メニューを開く">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="menu">
        <nav class="nav">
          <ul class="nav-list">
            {SITE_CONFIG.navigation.map((item) => (
              <li class="nav-list-item">
                <a href={item.href} class="nav-list-link">{item.label}</a>
                {item.submenu && (
                  <ul class="sub-menu">
                    {item.submenu.map((subItem) => (
                      <li class="sub-menu-item">
                        <a href={subItem.href} class="sub-menu-link">
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
          <div class="menu-actions">
            <LanguageSwitcher />
            <Button href="/contact" variant="solid" size="medium" class="menu-contact">
              {t('nav.contact')}
            </Button>
          </div>
        </nav>
      </div>
    </div>
  </Container>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    display: grid;
    place-items: center;
    width: 100%;
    z-index: var(--z-sticky);
    height: var(--headerHeightMobile);
    background-color: var(--c-bg);
    transition: transform var(--transition-slower) var(--ease-out-quart);
  }

  @media (min-width: 900px) {
    .header {
      height: var(--headerHeight);
    }
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .header-logo {
    flex-shrink: 0;
    z-index: var(--z-fixed);
  }

  /* Mobile Menu Button */
  .menu-button {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    margin-right: calc(var(--sp-sm) * -1);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: var(--z-fixed);
  }

  @media (min-width: 900px) {
    .menu-button {
      display: none;
    }
  }

  .menu-button span {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--c-text);
    transition: all var(--transition-base);
    position: absolute;
  }

  .menu-button span:nth-child(1) {
    transform: translateY(-6px);
  }

  .menu-button span:nth-child(3) {
    transform: translateY(6px);
  }

  .menu-button.is-open span:nth-child(1) {
    transform: translateY(0) rotate(45deg);
  }

  .menu-button.is-open span:nth-child(2) {
    opacity: 0;
  }

  .menu-button.is-open span:nth-child(3) {
    transform: translateY(0) rotate(-45deg);
  }

  /* Menu */
  .menu {
    position: fixed;
    top: var(--headerHeightMobile);
    left: 0;
    z-index: 1000;
    width: 100%;
    height: calc(100dvh - var(--headerHeightMobile));
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
    padding: var(--sp-xl) var(--sp-xl);
    background-color: var(--c-bg-alt);
    opacity: 0;
    overflow-y: hidden;
    visibility: hidden;
    transition-property: transform, opacity, background-color, visibility;
    transition-duration: var(--transition-slow);
    transition-timing-function: ease;
    will-change: transform, opacity, background-color, visibility;
  }

  @media (min-width: 900px) {
    .menu {
      position: static;
      height: auto;
      padding: 0;
      opacity: 1;
      visibility: visible;
      overflow-y: visible;
      background-color: transparent;
      display: block;
    }
  }

  .menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* Navigation */
  .nav {
    display: flex;
    flex-direction: column;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity var(--transition-slower) var(--ease-out-quart),
                transform var(--transition-slower) var(--ease-out-quart),
                visibility var(--transition-slower);
  }

  @media (min-width: 900px) {
    .nav {
      flex-direction: row;
      align-items: center;
      gap: var(--sp-xl);
      height: auto;
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  .menu.is-open .nav {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    list-style: none;
  }

  @media (min-width: 900px) {
    .nav-list {
      flex-direction: row;
      align-items: center;
      gap: var(--sp-xl);
    }
  }

  .nav-list-item {
    position: relative;
  }

  .nav-list-link {
    display: block;
    padding: var(--sp-sm) 0;
    color: var(--c-text);
    font-size: var(--fs-lg);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.025em;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  @media (min-width: 900px) {
    .nav-list-link {
      padding: var(--sp-xs) 0;
      font-size: var(--fs-sm);
    }
  }

  .nav-list-link:hover {
    color: var(--c-primary);
  }

  /* Sub Menu */
  .sub-menu {
    display: none;
    list-style: none;
    padding-left: var(--sp-lg);
    margin-top: var(--sp-sm);
    margin-bottom: var(--sp-sm);
  }

  @media (min-width: 900px) {
    .nav-list-item:hover .sub-menu {
      display: block;
      position: absolute;
      top: 100%;
      left: 0;
      background-color: var(--c-bg);
      border: 1px solid var(--c-border-light);
      border-radius: var(--radius-lg);
      padding: var(--sp-sm);
      min-width: 200px;
      box-shadow: var(--shadow-lg);
      margin-top: var(--sp-xs);
    }
  }

  .sub-menu-item {
    margin: 0;
  }

  .sub-menu-link {
    display: block;
    padding: var(--sp-sm);
    color: var(--c-text-sub);
    font-size: var(--fs-sm);
    text-decoration: none;
    transition: color var(--transition-base);
    white-space: nowrap;
  }

  @media (min-width: 900px) {
    .sub-menu-link {
      font-size: var(--fs-xs);
    }
  }

  .sub-menu-link:hover {
    color: var(--c-primary);
  }

  /* Contact Button */
  .menu-actions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .menu-actions {
      flex-direction: row;
      align-items: center;
      gap: var(--sp-lg);
    }
  }

  .menu-contact {
    --buttonWidth: 100%;
  }

  @media (min-width: 900px) {
    .menu-contact {
      --buttonWidth: auto;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuButton = document.querySelector('.menu-button');
    const menu = document.querySelector('.menu');
    const menuLinks = document.querySelectorAll('.menu a');
    let isOpen = false;

    // Reset state
    menu?.classList.remove('is-open');
    menuButton?.classList.remove('is-open');
    document.body.style.overflow = '';

    const toggleMenu = (e: Event) => {
      e.stopPropagation();
      menu?.classList.toggle('is-open');
      menuButton?.classList.toggle('is-open');
      document.body.style.overflow = isOpen ? '' : 'hidden';
      isOpen = !isOpen;
    };

    menuButton?.addEventListener('click', (e) => toggleMenu(e));
    
    menuLinks?.forEach((link) => {
      link.addEventListener('click', (e) => toggleMenu(e));
    });
  });
</script>

<script>
  // Header hide on scroll
  const header = document.getElementById('header');
  let lastScroll = 0;
  let ticking = false;

  const updateHeader = () => {
    const currentScroll = window.scrollY;

    if (currentScroll <= 0) {
      header?.classList.remove('is-hidden');
      lastScroll = currentScroll;
      ticking = false;
      return;
    }

    if (currentScroll > lastScroll && currentScroll > 100) {
      header?.classList.add('is-hidden');
    } else if (currentScroll < lastScroll) {
      header?.classList.remove('is-hidden');
    }

    lastScroll = currentScroll;
    ticking = false;
  };

  const requestTick = () => {
    if (!ticking) {
      requestAnimationFrame(updateHeader);
      ticking = true;
    }
  };

  window.addEventListener('scroll', requestTick, { passive: true });
</script>
