---
import { languages, getLangFromUrl, getLocalizedPath, type Language } from "../i18n/utils";

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// 移除当前语言前缀，获取基础路径
function getBasePath(path: string): string {
  const [, maybeLang, ...rest] = path.split("/");
  if (maybeLang in languages) {
    return `/${rest.join("/")}`;
  }
  return path;
}

const basePath = getBasePath(currentPath);
---

<div class="language-switcher">
  {Object.entries(languages).map(([lang, label]) => {
    const href = getLocalizedPath(basePath, lang as Language);
    const isActive = lang === currentLang;
    
    return (
      <a 
        href={href} 
        class:list={["language-switcher__link", { "language-switcher__link--active": isActive }]}
        aria-current={isActive ? "page" : undefined}
      >
        {label}
      </a>
    );
  })}
</div>

<style lang="scss">
  .language-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;

    &__link {
      padding: 0.25rem 0.75rem;
      text-decoration: none;
      color: var(--c-text);
      font-size: 0.9rem;
      border-radius: 4px;
      transition: all 0.3s;

      &:hover {
        background: var(--c-bg-secondary);
        color: var(--c-primary);
      }

      &--active {
        background: var(--c-primary);
        color: white;
        font-weight: 600;

        &:hover {
          background: var(--c-primary);
          color: white;
        }
      }
    }
  }
</style>
