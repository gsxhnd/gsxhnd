---
import Container from './Container.astro';
import Logo from './Logo.astro';
import { SITE_CONFIG } from '../config/site';
---

<footer class="footer">
  <Container size="large">
    <div class="footer-inner">
      <div class="footer-info">
        <Logo class="footer-logo" />
        <p class="footer-business-hours">
          营业时间: {SITE_CONFIG.company.businessHours}
          <span class="business-hours-note">{SITE_CONFIG.company.businessHoursNote}</span>
        </p>
        <ul class="footer-social">
          <li class="social-item">
            <a href={SITE_CONFIG.social.github} class="social-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            </a>
          </li>
          <li class="social-item">
            <a href={SITE_CONFIG.social.twitter} class="social-link" aria-label="Twitter" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
              </svg>
            </a>
          </li>
          <li class="social-item">
            <a href={SITE_CONFIG.social.linkedin} class="social-link" aria-label="Linkedin" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect width="4" height="12" x="2" y="9" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          </li>
          <li class="social-item">
            <a href={SITE_CONFIG.social.youtube} class="social-link" aria-label="Youtube" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17" />
                <path d="m10 15 5-3-5-3z" />
              </svg>
            </a>
          </li>
          <li class="social-item">
            <a href={SITE_CONFIG.social.instagram} class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <nav class="footer-nav">
        <div class="nav-group">
          <h3 class="nav-group-title">服务</h3>
          <ul class="nav-group-list">
            {SITE_CONFIG.footerNavigation.services.map((item) => (
              <li class="nav-group-item">
                <a href={item.href} class="nav-group-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="nav-group">
          <h3 class="nav-group-title">资源</h3>
          <ul class="nav-group-list">
            {SITE_CONFIG.footerNavigation.resources.map((item) => (
              <li class="nav-group-item">
                <a href={item.href} class="nav-group-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="nav-group">
          <h3 class="nav-group-title">公司</h3>
          <ul class="nav-group-list">
            {SITE_CONFIG.footerNavigation.company.map((item) => (
              <li class="nav-group-item">
                <a href={item.href} class="nav-group-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="nav-group">
          <h3 class="nav-group-title">法律</h3>
          <ul class="nav-group-list">
            {SITE_CONFIG.footerNavigation.legal.map((item) => (
              <li class="nav-group-item">
                <a href={item.href} class="nav-group-link">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </div>

      <div class="footer-copyright">
        <p class="copyright-text">
          &copy; {new Date().getFullYear()} <a href="/">{SITE_CONFIG.company.name}</a> All rights reserved.
        </p>
      </div>
  </Container>
</footer>

<style>
  .footer {
    padding: var(--sp-3xl) 0 var(--sp-lg);
    background-color: var(--c-primary-dark);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2xl);
    margin-bottom: var(--sp-xl);
  }

  @media (min-width: 900px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-3xl);
      margin-bottom: var(--sp-2xl);
    }
  }

  .footer-logo {
    z-index: var(--z-base);
  }

  .footer-logo :global(svg) {
    color: var(--c-text-inverse);
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
  }

  .footer-business-hours {
    color: var(--c-text-inverse-lightest);
    font-size: var(--fs-sm);
  }

  .business-hours-note {
    color: var(--c-text-inverse-sub);
    font-size: var(--fs-sm);
  }

  .footer-social {
    display: flex;
    gap: var(--sp-sm);
    list-style: none;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--c-text-inverse-light);
    transition: transform var(--transition-base);
  }

  .social-link:hover {
    transform: translateY(-2px);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-xl) var(--sp-lg);
  }

  @media (min-width: 600px) {
    .footer-nav {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-xl);
    }
  }

  .nav-group-title {
    margin-bottom: var(--sp-md);
    color: var(--c-text-inverse);
    font-size: var(--fs-sm);
    font-weight: 500;
  }

  .nav-group-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    list-style: none;
  }

  .nav-group-link {
    color: var(--c-text-inverse-sub);
    font-size: var(--fs-sm);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .nav-group-link:hover {
    color: var(--c-text-inverse);
  }

  .footer-copyright {
    padding-top: var(--sp-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .copyright-text {
    color: var(--c-text-inverse-sub);
    font-size: var(--fs-sm);
    text-align: center;
  }

  .copyright-text a {
    color: var(--c-text-inverse);
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .copyright-text a:hover {
    opacity: 0.7;
  }
</style>
