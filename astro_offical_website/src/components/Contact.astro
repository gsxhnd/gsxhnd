---
import Button from './Button.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Contact Section -->
<section class="contact" id="contact">
  <div class="contact__container">
    <div class="contact__header">
      <h2 class="contact__title">{t("contact.title")}</h2>
      <p class="contact__subtitle">{t("contact.subtitle")}</p>
    </div>
    <p class="contact__description">
      {t("contact.sectionDescription")}
    </p>
    <ul class="contact__list">
      {(t("contact.sectionItems") as unknown as string[]).map((item: string) => (
        <li>{item}</li>
      ))}
    </ul>
    <Button href={`/${lang}/contact/`} variant="solid-sub" size="medium">
      {t("contact.sectionCta")}
    </Button>
  </div>
</section>

<style lang="scss">
  .contact {
    padding: 4rem 1.5rem;
    background: var(--c-bg-inverse);
    color: var(--c-text-inverse);

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-inverse-sub);
      margin: 0;
    }

    &__description {
      color: var(--c-text-inverse-lightest);
      max-width: 700px;
      line-height: 1.8;
      font-size: 0.9rem;
      margin: 0 0 1.5rem;

      @media (min-width: 768px) {
        font-size: 0.95rem;
        margin: 0 0 2rem;
      }
    }

    &__list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.4rem;
      max-width: 700px;
      margin: 0 0 2rem;
      padding: 0;
      list-style: none;
      color: var(--c-text-inverse-sub);
      font-size: 0.85rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
        margin: 0 0 2.5rem;
        font-size: 0.9rem;
      }

      li {
        line-height: 1.6;

        &::before {
          content: "·";
          margin-right: 0.25rem;
        }
      }
    }
  }
</style>
