---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const worksList = t("works.list") as unknown as { slug: string; title: string; tag: string; category: string; description: string }[];
---

<Layout title={`${t("works.title")} | ${t("site.title")}`}>
  <section class="works-hero">
    <div class="works-hero__container">
      <h1>{t("works.title")}</h1>
      <p>{t("works.subtitle")}</p>
    </div>
  </section>

  <section class="works-list">
    <div class="works-list__container">
      {worksList.map((work) => (
        <a href={`/${lang}/works/${work.slug}`} class="work-detail">
          <h2>{work.title}</h2>
          <div class="work-detail__meta">
            <span class="work-detail__tag">{work.tag}</span>
            <span class="work-detail__category">{work.category}</span>
          </div>
          <p class="work-detail__description">{work.description}</p>
        </a>
      ))}
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .works-hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 3rem 1.5rem; text-align: center;
    @media (min-width: 768px) { padding: 4rem 2rem; }
    &__container {
      max-width: 1200px; margin: 0 auto;
      h1 { font-size: 2rem; margin: 0 0 0.5rem 0; @media (min-width: 768px) { font-size: 3rem; } }
      p { font-size: 1rem; margin: 0; opacity: 0.95; @media (min-width: 768px) { font-size: 1.2rem; } }
    }
  }
  .works-list {
    padding: 2.5rem 1.5rem; max-width: 1200px; margin: 0 auto;
    @media (min-width: 768px) { padding: 4rem 2rem; }
    &__container { display: grid; gap: 2rem; @media (min-width: 768px) { gap: 3rem; } }
  }
  .work-detail {
    display: block; text-decoration: none; color: inherit; padding: 1.5rem; background: var(--c-bg-secondary); border-radius: 8px; border-left: 4px solid var(--c-primary); transition: transform 0.2s ease;
    @media (min-width: 768px) { padding: 2rem; }
    &:hover { transform: translateX(4px); }
    h2 { margin: 0 0 0.8rem 0; font-size: 1.2rem; color: var(--c-text); @media (min-width: 768px) { font-size: 1.5rem; margin: 0 0 1rem 0; } }
    &__meta { display: flex; gap: 0.8rem; margin-bottom: 1rem; flex-wrap: wrap; @media (min-width: 768px) { gap: 1rem; } }
    &__tag { display: inline-block; background: #e8f0ff; color: var(--c-primary); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.75rem; font-weight: 500; @media (min-width: 768px) { padding: 0.4rem 1rem; font-size: 0.85rem; } }
    &__category { display: inline-block; background: var(--c-bg); color: var(--c-text-sub); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.75rem; border: 1px solid var(--c-border); @media (min-width: 768px) { padding: 0.4rem 1rem; font-size: 0.85rem; } }
    &__description { margin: 0; color: var(--c-text-sub); line-height: 1.8; font-size: 0.9rem; @media (min-width: 768px) { font-size: 1rem; } }
  }
</style>
