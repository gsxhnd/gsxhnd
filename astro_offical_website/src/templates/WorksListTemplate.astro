---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations } from "../i18n/utils";
import { SITE_CONFIG } from "../config/site";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const categories = t("works.categories") as unknown as string[];

interface WorkItem {
  slug: string;
  title: string;
  tag: string;
  category: string;
  description: string;
}

const worksList = t("works.list") as unknown as WorkItem[];
---

<Layout title={`${t("works.title")} | ${SITE_CONFIG.name}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">{t("works.title")}</h1>
      <p class="page-header__subtitle" id="works-subtitle" data-default={t("works.subtitle")}>
        {t("works.subtitle")}
      </p>
    </div>
  </section>

  <section class="works-list">
    <div class="works-list__container">
      <!-- Category Filter -->
      <div class="works-filter">
        {categories.map((cat: string, i: number) => (
          <button
            class={`works-filter__btn ${i === 0 ? "works-filter__btn--active" : ""}`}
            data-category={cat}
            data-is-all={i === 0 ? "true" : "false"}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Works Grid -->
      <div class="works-grid" id="works-grid">
        {worksList.map((work) => (
          <a href={`/${lang}/works/${work.slug}`} class="works-card" data-tag={work.tag}>
            <div class="works-card__image">
              <div class="works-card__image-placeholder"></div>
            </div>
            <h3 class="works-card__title">{work.title}</h3>
            <p class="works-card__category">{work.category}</p>
            <span class="works-card__tag">{work.tag}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".works-filter__btn");
    const cards = document.querySelectorAll<HTMLAnchorElement>(".works-card");
    const subtitle = document.getElementById("works-subtitle");
    const defaultSubtitle = subtitle?.dataset.default || "";

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("works-filter__btn--active"));
        btn.classList.add("works-filter__btn--active");

        const isAll = btn.dataset.isAll === "true";
        const category = btn.dataset.category || "";

        // Update subtitle to show selected category or default
        if (subtitle) {
          subtitle.textContent = isAll ? defaultSubtitle : category;
        }

        // Filter cards
        cards.forEach((card) => {
          if (isAll || card.dataset.tag === category) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  });
</script>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  .works-list {
    padding: 0 1.5rem 4rem;

    @media (min-width: 768px) {
      padding: 0 2rem 6rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }
  }

  .works-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;

    @media (min-width: 768px) {
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    &__btn {
      padding: 0.4rem 1.2rem;
      border: 1px solid var(--c-border);
      border-radius: 100px;
      background: transparent;
      color: var(--c-text-sub);
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;

      @media (min-width: 768px) {
        padding: 0.45rem 1.4rem;
        font-size: 0.85rem;
      }

      &:hover {
        border-color: var(--c-text);
        color: var(--c-text);
      }

      &--active {
        background: var(--c-text);
        color: var(--c-bg);
        border-color: var(--c-text);

        &:hover {
          color: var(--c-bg);
        }
      }
    }
  }

  .works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;

    @media (min-width: 640px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
    }

    @media (min-width: 900px) {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem 1.5rem;
    }
  }

  .works-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 0.75;
    }

    &__image {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 0.75rem;
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%);
    }

    &__title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 0.2rem 0;
      line-height: 1.4;

      @media (min-width: 768px) {
        font-size: 1.05rem;
      }
    }

    &__category {
      font-size: 0.8rem;
      color: var(--c-text-sub);
      margin: 0 0 0.5rem 0;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__tag {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border: 1px solid var(--c-border);
      border-radius: 100px;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      line-height: 1.4;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }
  }
</style>
