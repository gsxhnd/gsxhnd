---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const values = t("about.values.items") as unknown as { title: string; description: string }[];
const members = t("about.team.members") as unknown as { name: string; role: string }[];
---

<Layout title={`${t("about.title")} | ${t("site.title")}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">{t("about.title")}</h1>
      <p class="page-header__subtitle">{t("about.subtitle")}</p>
    </div>
  </section>

  <section class="strengths">
    <div class="strengths__container">
      <div class="strengths__item">
        <div class="strengths__text">
          <h2 class="strengths__heading">{t("about.strengths.heading")}</h2>
          <p class="strengths__description">{t("about.strengths.description")}</p>
        </div>
        <div class="strengths__image">
          <div class="strengths__image-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="technology">
    <div class="technology__container">
      <div class="technology__image">
        <div class="technology__image-placeholder"></div>
      </div>
      <div class="technology__text">
        <h2 class="technology__heading">{t("about.technology.heading")}</h2>
        <p class="technology__description">{t("about.technology.description")}</p>
      </div>
    </div>
  </section>

  <section class="values">
    <div class="values__container">
      <div class="values__header">
        <h2 class="values__title">{t("about.values.title")}</h2>
        <p class="values__subtitle">{t("about.values.subtitle")}</p>
      </div>
      <div class="values__list">
        {values.map((item) => (
          <div class="values__item">
            <h3 class="values__item-title">{item.title}</h3>
            <p class="values__item-description">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ceo-message" id="ceo-message">
    <div class="ceo-message__container">
      <div class="ceo-message__header">
        <h2 class="ceo-message__title">{t("about.ceoMessage.title")}</h2>
        <p class="ceo-message__subtitle">{t("about.ceoMessage.subtitle")}</p>
      </div>
      <div class="ceo-message__content">
        <div class="ceo-message__photo">
          <div class="ceo-message__photo-placeholder"></div>
        </div>
        <div class="ceo-message__text">
          <h3 class="ceo-message__heading">{t("about.ceoMessage.heading")}</h3>
          <p>{t("about.ceoMessage.p1")}</p>
          <p>{t("about.ceoMessage.p2")}</p>
          <p>{t("about.ceoMessage.p3")}</p>
          <p>{t("about.ceoMessage.p4")}</p>
          <div class="ceo-message__signature">
            <span class="ceo-message__role">{t("company.overview.ceoTitle")} {t("company.overview.ceo")}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="team">
    <div class="team__container">
      <div class="team__header">
        <h2 class="team__title">{t("about.team.title")}</h2>
        <p class="team__subtitle">{t("about.team.subtitle")}</p>
      </div>
      <p class="team__description">{t("about.team.description")}</p>
      <div class="team__grid">
        {members.map((member) => (
          <div class="team__member">
            <div class="team__member-photo">
              <div class="team__member-photo-placeholder"></div>
            </div>
            <p class="team__member-name">{member.name}</p>
            <p class="team__member-role">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;
    @media (min-width: 768px) { padding: 4rem 2rem 3rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__title { font-size: 2.5rem; font-weight: 700; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 3.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
  }

  .strengths {
    padding: 3rem 1.5rem;
    @media (min-width: 768px) { padding: 4rem 2rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__item { display: grid; grid-template-columns: 1fr; gap: 2rem; @media (min-width: 768px) { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; } }
    &__heading { font-size: 1.5rem; font-weight: 700; color: var(--c-text); margin: 0 0 1rem 0; @media (min-width: 768px) { font-size: 1.8rem; } }
    &__description { font-size: 0.9rem; line-height: 1.8; color: var(--c-text-sub); margin: 0; @media (min-width: 768px) { font-size: 0.95rem; } }
    &__image { aspect-ratio: 4 / 3; border-radius: 8px; overflow: hidden; }
    &__image-placeholder { width: 100%; height: 100%; background: var(--c-bg-secondary); }
  }

  .technology {
    padding: 3rem 1.5rem; background: var(--c-bg-secondary);
    @media (min-width: 768px) { padding: 4rem 2rem; }
    &__container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 2rem; @media (min-width: 768px) { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; } }
    &__image { aspect-ratio: 4 / 3; border-radius: 8px; overflow: hidden; }
    &__image-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%); }
    &__heading { font-size: 1.5rem; font-weight: 700; color: var(--c-text); margin: 0 0 1rem 0; @media (min-width: 768px) { font-size: 1.8rem; } }
    &__description { font-size: 0.9rem; line-height: 1.8; color: var(--c-text-sub); margin: 0; @media (min-width: 768px) { font-size: 0.95rem; } }
  }

  .values {
    padding: 4rem 1.5rem; @media (min-width: 768px) { padding: 6rem 2rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__header { margin-bottom: 3rem; @media (min-width: 768px) { margin-bottom: 4rem; } }
    &__title { font-size: 2rem; font-weight: 700; font-style: italic; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 2.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
    &__list { display: flex; flex-direction: column; gap: 2.5rem; @media (min-width: 768px) { gap: 3rem; padding-left: 2rem; border-left: 1px solid var(--c-border); } }
    &__item { max-width: 700px; }
    &__item-title { font-size: 1.1rem; font-weight: 600; color: var(--c-text); margin: 0 0 0.75rem 0; @media (min-width: 768px) { font-size: 1.2rem; } }
    &__item-description { font-size: 0.875rem; line-height: 1.8; color: var(--c-text-sub); margin: 0; @media (min-width: 768px) { font-size: 0.95rem; } }
  }

  .ceo-message {
    padding: 4rem 1.5rem; background: var(--c-bg-secondary); @media (min-width: 768px) { padding: 6rem 2rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__header { margin-bottom: 2.5rem; @media (min-width: 768px) { margin-bottom: 3rem; } }
    &__title { font-size: 2rem; font-weight: 700; font-style: italic; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 2.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
    &__content { display: grid; grid-template-columns: 1fr; gap: 2rem; @media (min-width: 768px) { grid-template-columns: 200px 1fr; gap: 3rem; } }
    &__photo { width: 160px; height: 160px; border-radius: 50%; overflow: hidden; @media (min-width: 768px) { width: 200px; height: 200px; } }
    &__photo-placeholder { width: 100%; height: 100%; background: var(--c-border); }
    &__heading { font-size: 1.2rem; font-weight: 600; color: var(--c-text); margin: 0 0 1.5rem 0; @media (min-width: 768px) { font-size: 1.3rem; } }
    &__text { p { font-size: 0.875rem; line-height: 1.8; color: var(--c-text-sub); margin: 0 0 1rem 0; @media (min-width: 768px) { font-size: 0.95rem; } } }
    &__signature { margin-top: 1.5rem; }
    &__role { font-size: 0.85rem; color: var(--c-text); font-weight: 500; }
  }

  .team {
    padding: 4rem 1.5rem; @media (min-width: 768px) { padding: 6rem 2rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__header { margin-bottom: 1.5rem; @media (min-width: 768px) { margin-bottom: 2rem; } }
    &__title { font-size: 2rem; font-weight: 700; font-style: italic; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 2.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
    &__description { font-size: 0.875rem; line-height: 1.8; color: var(--c-text-sub); max-width: 800px; margin: 0 0 3rem 0; @media (min-width: 768px) { font-size: 0.95rem; } }
    &__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; @media (min-width: 640px) { grid-template-columns: repeat(3, 1fr); } @media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); gap: 2.5rem; } }
    &__member { text-align: center; }
    &__member-photo { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin: 0 auto 1rem; @media (min-width: 768px) { width: 150px; height: 150px; } }
    &__member-photo-placeholder { width: 100%; height: 100%; background: var(--c-bg-secondary); }
    &__member-name { font-size: 0.9rem; font-weight: 600; color: var(--c-text); margin: 0 0 0.25rem 0; }
    &__member-role { font-size: 0.8rem; color: var(--c-text-sub); margin: 0; }
  }
</style>
