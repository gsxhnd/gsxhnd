---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { getCollection } from "astro:content";
import { type Language, useTranslations, dateLocales } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allNews = await getCollection("news", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const sortedNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const works = (t("home.works") as unknown as any[]);
---

<Layout title={t("site.title")}>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__container">
      <h1 class="hero__title">
        <span>{t("hero.line1")}</span>
        <span>{t("hero.line2")}</span>
      </h1>
      <div class="hero__image">
        <div class="hero__image-placeholder"></div>
      </div>
    </div>
  </section>

  <!-- Partners Section -->
  <section class="partners">
    <div class="partners__container">
      <p class="partners__title">{t("partners.title")}</p>
      <div class="partners__track">
        {["Nagi co.jp partner", "CorporateX", "LoopStorm", "Loopstream", "LOGOPIA", "Corpstream", "Corpstream"].map((name) => (
          <div class="partners__item">
            <span class="partners__logo">{name}</span>
          </div>
        ))}
        {["Nagi co.jp partner", "CorporateX", "LoopStorm", "Loopstream", "LOGOPIA", "Corpstream", "Corpstream"].map((name) => (
          <div class="partners__item" aria-hidden="true">
            <span class="partners__logo">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <div class="works__header">
        <h2 class="works__title">{t("home.worksTitle")}</h2>
        <p class="works__subtitle">{t("home.worksSubtitle")}</p>
        <a href={`/${lang}/works/`} class="works__link">{t("home.worksViewAll")}</a>
      </div>
      <div class="works__list">
        {works.map((work: any, i: number) => {
          const slugs = ["ec-platform-redesign", "corporate-branding", "mobile-banking-app", "saas-dashboard-platform"];
          return (
            <a href={`/${lang}/works/${slugs[i]}`} class="work-item">
              <div class="work-item__image">
                <div class="work-item__image-placeholder"></div>
              </div>
              <div class="work-item__content">
                <h3 class="work-item__title">{work.title}</h3>
                <p class="work-item__description">{work.description}</p>
                <span class="work-item__link">{t("home.worksViewDetails")}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <div class="about__header">
        <h2 class="about__title">{t("home.aboutTitle")}</h2>
        <p class="about__subtitle">{t("home.aboutSubtitle")}</p>
      </div>
      <div class="about__content">
        <p>
          {t("home.aboutP1")}<br />
          {t("home.aboutP1b")}
        </p>
        <p>
          {t("home.aboutP2")}<br />
          {t("home.aboutP2b")}<br />
          {t("home.aboutP2c")}
        </p>
        <p>
          {t("home.aboutP3")}<br />
          {t("home.aboutP3b")}<br />
          {t("home.aboutP3c")}
        </p>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <div class="news__header">
        <div class="news__header-left">
          <h2 class="news__title">{t("home.newsTitle")}</h2>
          <p class="news__subtitle">{t("home.newsSubtitle")}</p>
        </div>
        <a href={`/${lang}/news/`} class="news__link">{t("home.newsViewAll")}</a>
      </div>
      <div class="news__list">
        {sortedNews.map((entry) => (
          <a href={`/${lang}/news/${entry.id}`} class="news-item">
            <time class="news-item__date">
              {entry.data.date.toLocaleDateString(dateLocales[lang], { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".")}
            </time>
            <span class="news-item__type">{entry.data.type || t("home.newsDefaultType")}</span>
            <span class="news-item__title">{entry.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  /* Hero Section */
  .hero {
    padding: 4rem 1.5rem 3rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem 4rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.4;
      color: var(--c-text);
      margin: 0 0 2rem 0;

      span {
        display: block;
      }

      @media (min-width: 640px) {
        font-size: 2.5rem;
      }

      @media (min-width: 768px) {
        font-size: 3.5rem;
        margin: 0 0 3rem 0;
      }
    }

    &__image {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      overflow: hidden;

      @media (min-width: 768px) {
        aspect-ratio: 2.5 / 1;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%);
    }
  }

  /* Partners Section */
  .partners {
    padding: 2.5rem 1.5rem;
    border-top: 1px solid var(--c-border-light);
    border-bottom: 1px solid var(--c-border-light);
    overflow: hidden;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      text-align: center;
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0 0 2rem 0;
      letter-spacing: 0.02em;

      @media (min-width: 768px) {
        font-size: 0.95rem;
        margin: 0 0 2.5rem 0;
      }
    }

    &__track {
      display: flex;
      gap: 2rem;
      animation: scroll 30s linear infinite;
      width: fit-content;

      @media (min-width: 768px) {
        gap: 3rem;
      }
    }

    &__item {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 1rem;
    }

    &__logo {
      font-size: 0.85rem;
      color: var(--c-text-light);
      white-space: nowrap;
      font-weight: 500;
      letter-spacing: 0.05em;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Works Section */
  .works {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        margin-bottom: 3.5rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0 0 0.75rem 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 3rem;

      @media (min-width: 768px) {
        gap: 4rem;
      }
    }
  }

  .work-item {
    display: block;
    text-decoration: none;
    color: inherit;

    &__image {
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        aspect-ratio: 16 / 9;
        max-width: 800px;
        margin-left: auto;
        margin-right: 0;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }

    &__content {
      @media (min-width: 768px) {
        max-width: 600px;
      }
    }

    &__title {
      font-size: 1.2rem;
      font-weight: 600;
      margin: 0 0 0.75rem 0;
      color: var(--c-text);

      @media (min-width: 768px) {
        font-size: 1.4rem;
      }
    }

    &__description {
      font-size: 0.875rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0 0 1rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      transition: color 0.2s ease;
    }

    &:hover &__link {
      color: var(--c-text);
    }
  }

  /* About Section */
  .about {
    padding: 4rem 1.5rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__content {
      max-width: 700px;

      p {
        font-size: 0.95rem;
        line-height: 2;
        color: var(--c-text-sub);
        margin: 0 0 1.5rem 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }

        &:last-child {
          margin-bottom: 0;
        }
      }
    }
  }

  /* News Section */
  .news {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;
      white-space: nowrap;

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--c-border);
    }
  }

  .news-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    @media (min-width: 768px) {
      grid-template-columns: 110px 100px 1fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 0;
    }

    &:hover {
      opacity: 0.6;
    }

    &__date {
      font-size: 0.8rem;
      color: var(--c-text-light);
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      font-weight: 500;
      width: fit-content;
      white-space: nowrap;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    &__title {
      font-size: 0.9rem;
      color: var(--c-text);
      font-weight: 400;
      line-height: 1.5;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }
</style>
