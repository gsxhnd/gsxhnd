---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const sections = t("privacy.sections") as unknown as Array<{
  id: string;
  title: string;
  content?: string;
  items?: string[];
}>;
---

<Layout title={`${t("privacy.title")} | ${t("site.title")}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">Privacy Policy</h1>
      <p class="page-header__subtitle">{t("privacy.title")}</p>
    </div>
  </section>

  <section class="privacy-content">
    <div class="privacy-content__container">
      <div class="privacy-content__intro">
        <p>{t("privacy.intro")}</p>
      </div>

      {sections.map((section) => (
        <div class="privacy-content__section" id={section.id}>
          <h2 class="privacy-content__section-title">{section.title}</h2>
          {section.content && (
            <div class="privacy-content__section-text">
              <p>{section.content}</p>
            </div>
          )}
          {section.items && (
            <ul class="privacy-content__section-list">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </div>
      ))}

      <div class="privacy-content__contact" id="contact">
        <h2 class="privacy-content__section-title">{t("privacy.contact.title")}</h2>
        <p class="privacy-content__contact-text">{t("privacy.contact.description")}</p>
        <div class="privacy-content__contact-card">
          <h3>{t("company.overview.companyName")}</h3>
          <p>{t("company.overview.address")}</p>
          <p>TEL: {t("company.overview.tel")}</p>
          <p>Email: {t("company.overview.email")}</p>
        </div>
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;
    @media (min-width: 768px) { padding: 4rem 2rem 3rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__title { font-size: 2.5rem; font-weight: 700; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 3.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
  }

  .privacy-content {
    padding: 2rem 1.5rem 4rem;
    @media (min-width: 768px) { padding: 3rem 2rem 6rem; }
    &__container { max-width: 800px; margin: 0 auto; }
    &__intro {
      margin-bottom: 3rem;
      p { font-size: 0.9rem; line-height: 1.8; color: var(--c-text-sub); margin: 0; }
    }
    &__section {
      margin-bottom: 2.5rem;
      &:last-child { margin-bottom: 0; }
    }
    &__section-title {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 1rem 0;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--c-border);
    }
    &__section-text {
      p {
        font-size: 0.9rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin: 0 0 1rem 0;
        &:last-child { margin-bottom: 0; }
      }
    }
    &__section-list {
      margin: 1rem 0 0 0;
      padding-left: 1.5rem;
      li {
        font-size: 0.9rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin-bottom: 0.5rem;
        &:last-child { margin-bottom: 0; }
      }
    }
    &__contact {
      margin-top: 4rem;
      padding-top: 3rem;
      border-top: 2px solid var(--c-border);
    }
    &__contact-text {
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0 0 1.5rem 0;
    }
    &__contact-card {
      background: var(--c-bg-secondary);
      border-radius: 8px;
      padding: 1.5rem;
      h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--c-text);
        margin: 0 0 1rem 0;
      }
      p {
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--c-text-sub);
        margin: 0 0 0.5rem 0;
        &:last-child { margin-bottom: 0; }
      }
    }
  }
</style>