---
import Layout from "../layouts/Layout.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const inquiryTypes = t("contact.page.inquiryTypes") as unknown as string[];
---

<Layout title={`${t("contact.title")} | ${t("site.title")}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">{t("contact.title")}</h1>
      <p class="page-header__subtitle">{t("contact.subtitle")}</p>
    </div>
  </section>

  <section class="contact-form-section">
    <div class="contact-form-section__container">
      <p class="contact-form-section__intro">{t("contact.page.intro")}</p>

      <form class="contact-form" action="#" method="POST">
        <div class="form-group">
          <label class="form-label">
            {t("contact.page.inquiryType")}
            <span class="form-required">{t("contact.page.required")}</span>
          </label>
          <div class="form-radio-group">
            {inquiryTypes.map((type: string, i: number) => (
              <label class="form-radio">
                <input type="radio" name="inquiry_type" value={`type_${i}`} required={i === 0} />
                <span class="form-radio__label">{type}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="message">
            {t("contact.page.inquiryContent")}
            <span class="form-required">{t("contact.page.required")}</span>
          </label>
          <textarea id="message" name="message" rows="8" required placeholder={t("contact.page.inquiryPlaceholder")}></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="name">
            {t("contact.page.name")}
            <span class="form-required">{t("contact.page.required")}</span>
          </label>
          <input type="text" id="name" name="name" required placeholder={t("contact.page.namePlaceholder")} />
        </div>

        <div class="form-group">
          <label class="form-label" for="company">
            {t("contact.page.companyName")}
            <span class="form-required">{t("contact.page.required")}</span>
          </label>
          <input type="text" id="company" name="company" required placeholder={t("contact.page.companyPlaceholder")} />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">
            {t("contact.page.email")}
            <span class="form-required">{t("contact.page.required")}</span>
          </label>
          <input type="email" id="email" name="email" required placeholder="example@company.com" />
        </div>

        <div class="form-group">
          <label class="form-label" for="phone">
            {t("contact.page.phone")}
            <span class="form-optional">{t("contact.page.optional")}</span>
          </label>
          <input type="tel" id="phone" name="phone" placeholder={t("contact.page.phonePlaceholder")} />
        </div>

        <div class="form-group form-group--checkbox">
          <label class="form-checkbox">
            <input type="checkbox" name="privacy" required />
            <span class="form-checkbox__label">
              {t("contact.page.privacyAgree")} <a href={`/${lang}/privacy/`} target="_blank">{t("contact.page.privacyPolicy")}</a>
            </span>
          </label>
        </div>

        <div class="form-group form-group--submit">
          <button type="submit" class="form-submit">{t("contact.page.submit")}</button>
        </div>
      </form>
    </div>
  </section>
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem; @media (min-width: 768px) { padding: 4rem 2rem 3rem; }
    &__container { max-width: 1200px; margin: 0 auto; }
    &__title { font-size: 2.5rem; font-weight: 700; color: var(--c-text); margin: 0 0 0.25rem 0; @media (min-width: 768px) { font-size: 3.5rem; } }
    &__subtitle { font-size: 0.85rem; color: var(--c-text-sub); margin: 0; }
  }
  .contact-form-section {
    padding: 3rem 1.5rem 4rem; background: var(--c-bg-secondary); @media (min-width: 768px) { padding: 4rem 2rem 6rem; }
    &__container { max-width: 700px; margin: 0 auto; }
    &__intro { font-size: 0.9rem; line-height: 1.8; color: var(--c-text-sub); margin: 0 0 2.5rem 0; @media (min-width: 768px) { font-size: 0.95rem; margin: 0 0 3rem 0; } }
  }
  .contact-form { display: flex; flex-direction: column; gap: 2rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-label { font-size: 0.9rem; font-weight: 600; color: var(--c-text); display: flex; align-items: center; gap: 0.5rem; }
  .form-required { display: inline-block; font-size: 0.7rem; font-weight: 500; color: var(--c-text-inverse); background: var(--c-primary); padding: 0.1rem 0.4rem; border-radius: 2px; }
  .form-optional { display: inline-block; font-size: 0.7rem; font-weight: 500; color: var(--c-text-sub); background: var(--c-border); padding: 0.1rem 0.4rem; border-radius: 2px; }
  .form-radio-group { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.25rem; }
  .form-radio {
    display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
    input[type="radio"] { width: 18px; height: 18px; accent-color: var(--c-primary); cursor: pointer; }
    &__label { font-size: 0.9rem; color: var(--c-text); }
  }
  input[type="text"], input[type="email"], input[type="tel"], textarea {
    width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--c-border); border-radius: 4px; font-size: 0.9rem; font-family: inherit; color: var(--c-text); background: var(--c-bg); transition: border-color 0.2s;
    &::placeholder { color: var(--c-text-light); }
    &:focus { outline: none; border-color: var(--c-primary); }
  }
  textarea { resize: vertical; min-height: 160px; }
  .form-group--checkbox { margin-top: 0.5rem; }
  .form-checkbox {
    display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
    input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--c-primary); cursor: pointer; }
    &__label { font-size: 0.85rem; color: var(--c-text-sub); a { color: var(--c-text); text-decoration: underline; &:hover { color: var(--c-primary); } } }
  }
  .form-group--submit { display: flex; justify-content: center; margin-top: 1rem; }
  .form-submit {
    display: inline-block; min-width: 240px; padding: 1rem 2rem; background: var(--c-primary); color: var(--c-text-inverse); border: none; border-radius: 4px; font-size: 0.95rem; font-weight: 500; font-family: inherit; cursor: pointer; transition: background 0.2s; text-align: center;
    @media (min-width: 768px) { min-width: 280px; }
    &:hover { background: var(--c-primary-light); }
    &:active { transform: scale(0.98); }
  }
</style>
