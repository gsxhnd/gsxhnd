---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations, dateLocales } from "../i18n/utils";
import { SITE_CONFIG } from "../config/site";
import type { Page } from "astro";

interface Props {
  lang: Language;
  page: Page<any>;
}

const { lang, page } = Astro.props;
const t = useTranslations(lang);

const categories = t("news.categories") as unknown as string[];

const totalPages = page.lastPage;
const currentPage = page.currentPage;
const getPageUrl = (pageNum: number) => {
  if (pageNum === 1) return `/${lang}/news/`;
  return `/${lang}/news/${pageNum}/`;
};
---

<Layout title={`${t("news.title")} | ${SITE_CONFIG.name}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">{t("news.title")}</h1>
      <p class="page-header__subtitle">{t("news.subtitle")}</p>
    </div>
  </section>

  <section class="news-list">
    <div class="news-list__container">
      <!-- Category Filter -->
      <div class="news-filter">
        {categories.map((cat: string, i: number) => (
          <button
            class={`news-filter__btn ${i === 0 ? "news-filter__btn--active" : ""}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- News Items -->
      {page.data.length > 0 ? (
        <div class="news-list__items">
          {page.data.map((entry: any) => (
            <a href={`/${lang}/news/${entry.id}`} class="news-item" data-type={entry.data.type || t("news.defaultType")}>
              <time class="news-item__date">
                {entry.data.date.toLocaleDateString(dateLocales[lang], { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".")}
              </time>
              <span class="news-item__type">{entry.data.type || t("news.defaultType")}</span>
              <span class="news-item__title">{entry.data.title}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="news-list__empty">{t("news.empty")}</p>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <nav class="pagination" aria-label={t("news.paginationLabel")}>
          {currentPage <= 1 ? (
            <span class="pagination__btn pagination__btn--disabled">{t("news.first")}</span>
          ) : (
            <a href={getPageUrl(1)} class="pagination__btn">{t("news.first")}</a>
          )}

          {currentPage <= 1 ? (
            <span class="pagination__btn pagination__btn--disabled pagination__btn--arrow">&lt;</span>
          ) : (
            <a href={getPageUrl(currentPage - 1)} class="pagination__btn pagination__btn--arrow">&lt;</a>
          )}

          {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) => (
            num === currentPage ? (
              <span class="pagination__btn pagination__btn--current">{num}</span>
            ) : (
              <a href={getPageUrl(num)} class="pagination__btn pagination__btn--page">{num}</a>
            )
          ))}

          {currentPage >= totalPages ? (
            <span class="pagination__btn pagination__btn--disabled pagination__btn--arrow">&gt;</span>
          ) : (
            <a href={getPageUrl(currentPage + 1)} class="pagination__btn pagination__btn--arrow">&gt;</a>
          )}

          {currentPage >= totalPages ? (
            <span class="pagination__btn pagination__btn--disabled">{t("news.last")}</span>
          ) : (
            <a href={getPageUrl(totalPages)} class="pagination__btn">{t("news.last")}</a>
          )}
        </nav>
      )}
    </div>
  </section>

  <Contact />
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".news-filter__btn");
    const items = document.querySelectorAll<HTMLAnchorElement>(".news-item");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("news-filter__btn--active"));
        btn.classList.add("news-filter__btn--active");

        const category = btn.dataset.category;
        const isAll = btn === buttons[0];

        items.forEach((item) => {
          if (isAll || item.dataset.type === category) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        });
      });
    });
  });
</script>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  .news-list {
    padding: 0 1.5rem 4rem;

    @media (min-width: 768px) {
      padding: 0 2rem 6rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__items {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--c-border);
    }

    &__empty {
      text-align: center;
      color: var(--c-text-sub);
      padding: 3rem 0;
      font-size: 0.95rem;
    }
  }

  .news-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;

    @media (min-width: 768px) {
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    &__btn {
      padding: 0.4rem 1.2rem;
      border: 1px solid var(--c-border);
      border-radius: 100px;
      background: transparent;
      color: var(--c-text-sub);
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;

      @media (min-width: 768px) {
        padding: 0.45rem 1.4rem;
        font-size: 0.85rem;
      }

      &:hover {
        border-color: var(--c-text);
        color: var(--c-text);
      }

      &--active {
        background: var(--c-text);
        color: var(--c-bg);
        border-color: var(--c-text);

        &:hover {
          color: var(--c-bg);
        }
      }
    }
  }

  .news-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    @media (min-width: 768px) {
      grid-template-columns: 110px 100px 1fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 0;
    }

    &:hover {
      opacity: 0.6;
    }

    &__date {
      font-size: 0.8rem;
      color: var(--c-text-light);
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      font-weight: 500;
      width: fit-content;
      white-space: nowrap;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    &__title {
      font-size: 0.9rem;
      color: var(--c-text);
      font-weight: 400;
      line-height: 1.5;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    margin-top: 3rem;

    @media (min-width: 768px) {
      gap: 0.5rem;
      margin-top: 4rem;
    }

    &__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 36px;
      height: 36px;
      padding: 0 0.6rem;
      border: 1px solid var(--c-border);
      border-radius: 4px;
      font-size: 0.8rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: all 0.2s ease;
      font-family: inherit;
      white-space: nowrap;

      @media (min-width: 768px) {
        min-width: 40px;
        height: 40px;
        font-size: 0.85rem;
      }

      &:hover:not(&--disabled):not(&--current) {
        border-color: var(--c-text);
        color: var(--c-text);
      }

      &--current {
        background: var(--c-text);
        color: var(--c-bg);
        border-color: var(--c-text);
      }

      &--disabled {
        color: var(--c-text-lightest, #ccc);
        border-color: var(--c-border-light);
        cursor: default;
      }

      &--arrow {
        font-size: 0.85rem;
        min-width: 36px;

        @media (min-width: 768px) {
          min-width: 40px;
        }
      }

      &--page {
        min-width: 36px;

        @media (min-width: 768px) {
          min-width: 40px;
        }
      }
    }
  }
</style>
