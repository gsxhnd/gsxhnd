---
import Layout from "../layouts/Layout.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const slugToKey: Record<string, string> = {
  "ec-platform-redesign": "ecPlatformRedesign",
  "corporate-branding": "corporateBranding",
  "mobile-banking-app": "mobileBankingApp",
  "saas-dashboard-platform": "saasDashboardPlatform",
};

const key = slugToKey[slug];
const detail = t(`works.detail.${key}`) as unknown as {
  pageTitle: string;
  sections: { heading: string; content?: string; items?: string[] }[];
};
---

<Layout title={`${detail.pageTitle} | ${t("site.title")}`}>
  <section class="work-detail">
    <div class="work-detail__container">
      <article class="work-article">
        <header class="work-article__header">
          <h1>{detail.pageTitle}</h1>
          {(() => {
            const worksList = t("works.list") as unknown as any[];
            const work = worksList.find((w: any) => w.slug === slug);
            return work ? (
              <div class="work-meta">
                <span class="work-meta__tag">{work.tag}</span>
                <span class="work-meta__category">{work.category}</span>
              </div>
            ) : null;
          })()}
        </header>

        <div class="work-article__content">
          {detail.sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              {section.content && <p>{section.content}</p>}
              {section.items && (
                <ul>
                  {section.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </>
          ))}
        </div>

        <div class="work-article__footer">
          <a href={`/${lang}/works/`} class="work-back-link">{t("works.backToList")}</a>
        </div>
      </article>
    </div>
  </section>
</Layout>

<style lang="scss">
  .work-detail {
    padding: 2rem 1.5rem; background: var(--c-bg-secondary);
    @media (min-width: 768px) { padding: 3rem 2rem; }
    &__container { max-width: 800px; margin: 0 auto; }
  }
  .work-article {
    background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    @media (min-width: 768px) { padding: 3rem; }
    &__header {
      margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--c-border-light);
      @media (min-width: 768px) { margin-bottom: 2rem; padding-bottom: 2rem; }
      h1 { font-size: 1.5rem; margin-bottom: 0.8rem; color: var(--c-text); @media (min-width: 768px) { font-size: 2rem; margin-bottom: 1rem; } }
    }
    &__content {
      color: var(--c-text-sub); line-height: 1.8;
      p { margin-bottom: 1rem; font-size: 0.9rem; @media (min-width: 768px) { margin-bottom: 1.5rem; font-size: 1rem; } }
      h2 { font-size: 1.2rem; margin: 1.5rem 0 0.8rem; color: var(--c-text); @media (min-width: 768px) { font-size: 1.5rem; margin: 2rem 0 1rem; } }
      ul { margin-bottom: 1rem; margin-left: 1.2rem; @media (min-width: 768px) { margin-bottom: 1.5rem; margin-left: 1.5rem; } li { margin-bottom: 0.4rem; font-size: 0.9rem; @media (min-width: 768px) { margin-bottom: 0.5rem; font-size: 1rem; } } }
    }
    &__footer { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--c-border-light); @media (min-width: 768px) { margin-top: 2rem; padding-top: 2rem; } }
  }
  .work-meta {
    display: flex; gap: 0.8rem; flex-wrap: wrap; @media (min-width: 768px) { gap: 1rem; }
  }
  .work-meta__tag { display: inline-block; background: #e8f0ff; color: var(--c-primary); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.75rem; font-weight: 500; @media (min-width: 768px) { padding: 0.4rem 1rem; font-size: 0.85rem; } }
  .work-meta__category { display: inline-block; background: var(--c-bg); color: var(--c-text-sub); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.75rem; border: 1px solid var(--c-border); @media (min-width: 768px) { padding: 0.4rem 1rem; font-size: 0.85rem; } }
  .work-back-link { color: var(--c-primary); text-decoration: none; font-weight: 600; transition: color 0.3s; font-size: 0.9rem; @media (min-width: 768px) { font-size: 1rem; } &:hover { color: var(--c-primary-light); } }
</style>
