---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { type Language, useTranslations } from "../i18n/utils";
import { SITE_CONFIG } from "../config/site";

interface Props {
  lang: Language;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);

// Convert kebab-case slug to camelCase key
const detailKey = slug.replace(/-([a-z])/g, (_, c) => c.toUpperCase());

interface WorkListItem {
  slug: string;
  title: string;
  tag: string;
  category: string;
  description: string;
}

interface DetailSection {
  heading: string;
  content?: string;
  items?: string[];
}

interface WorkDetail {
  pageTitle: string;
  sections: DetailSection[];
}

const worksList = t("works.list") as unknown as WorkListItem[];
const workItem = worksList.find((w) => w.slug === slug);
const detail = t(`works.detail.${detailKey}`) as unknown as WorkDetail;
---

<Layout title={`${detail.pageTitle} | ${SITE_CONFIG.name}`}>
  <section class="page-header">
    <div class="page-header__container">
      <div class="page-header__breadcrumb">
        <a href={`/${lang}/works/`} class="page-header__back">{t("works.title")}</a>
        <span class="page-header__separator">/</span>
        <span class="page-header__current">{detail.pageTitle}</span>
      </div>
      {workItem && <span class="page-header__tag">{workItem.tag}</span>}
      <h1 class="page-header__title">{detail.pageTitle}</h1>
      {workItem && <p class="page-header__category">{workItem.category}</p>}
    </div>
  </section>

  <div class="work-detail__image">
    <div class="work-detail__image-placeholder"></div>
  </div>

  <article class="work-detail">
    <div class="work-detail__container">
      {detail.sections.map((section) => (
        <div class="work-detail__section">
          <h2 class="work-detail__heading">{section.heading}</h2>
          {section.content && (
            <p class="work-detail__content">{section.content}</p>
          )}
          {section.items && (
            <ul class="work-detail__list">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </article>

  <div class="work-back">
    <a href={`/${lang}/works/`} class="work-back__link">{t("works.backToList")}</a>
  </div>

  <Contact />
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
    }

    &__breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.8rem;
      color: var(--c-text-sub);
    }

    &__back {
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }

    &__separator {
      color: var(--c-text-lightest, #ccc);
    }

    &__current {
      color: var(--c-text-light);
    }

    &__tag {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border: 1px solid var(--c-border);
      border-radius: 100px;
      font-size: 0.75rem;
      color: var(--c-text-sub);
      margin-bottom: 0.75rem;
    }

    &__title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;
      line-height: 1.4;

      @media (min-width: 768px) {
        font-size: 2rem;
      }
    }

    &__category {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  .work-detail {
    padding: 2rem 1.5rem;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__image {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 1.5rem;

      @media (min-width: 768px) {
        padding: 0 2rem;
      }
    }

    &__image-placeholder {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%);
      border-radius: 8px;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
    }

    &__section {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }

      &:last-child {
        margin-bottom: 0;
      }
    }

    &__heading {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 0.75rem 0;

      @media (min-width: 768px) {
        font-size: 1.35rem;
        margin: 0 0 1rem 0;
      }
    }

    &__content {
      color: var(--c-text-sub);
      line-height: 1.8;
      font-size: 0.9rem;
      margin: 0 0 0.75rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__list {
      margin: 0 0 0 1.2rem;
      list-style: disc;
      color: var(--c-text-sub);

      @media (min-width: 768px) {
        margin: 0 0 0 1.5rem;
      }

      li {
        margin-bottom: 0.4rem;
        line-height: 1.6;
        font-size: 0.9rem;

        @media (min-width: 768px) {
          font-size: 0.95rem;
        }
      }
    }
  }

  .work-back {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;

    @media (min-width: 768px) {
      padding: 0 2rem 6rem;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }
  }
</style>
