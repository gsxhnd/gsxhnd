---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import Button from "../components/Button.astro";
import { type Language, useTranslations } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface ServiceSection {
  key: string;
  number: string;
  anchorId: string;
  titleKey: string;
  descriptionKey: string;
  itemsKey: string;
}

const serviceSections: ServiceSection[] = [
  {
    key: "webDev",
    number: "01",
    anchorId: "web-development",
    titleKey: "services.webDev.title",
    descriptionKey: "services.webDev.description",
    itemsKey: "services.webDev.items",
  },
  {
    key: "mobile",
    number: "02",
    anchorId: "mobile-apps",
    titleKey: "services.mobile.title",
    descriptionKey: "services.mobile.description",
    itemsKey: "services.mobile.items",
  },
  {
    key: "uiux",
    number: "03",
    anchorId: "uiux-design",
    titleKey: "services.uiux.title",
    descriptionKey: "services.uiux.description",
    itemsKey: "services.uiux.items",
  },
  {
    key: "strategy",
    number: "04",
    anchorId: "digital-strategy",
    titleKey: "services.strategy.title",
    descriptionKey: "services.strategy.description",
    itemsKey: "services.strategy.items",
  },
];

const faqItems = t("services.faq.items") as unknown as {
  question: string;
  answer: string;
}[];
---

<Layout title={`${t("services.title")} | ${t("site.title")}`}>
  <!-- Page Header -->
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">{t("services.title")}</h1>
      <p class="page-header__subtitle">{t("services.subtitle")}</p>
    </div>
  </section>

  <!-- Introduction -->
  <section class="services-intro">
    <div class="services-intro__container">
      <p class="services-intro__text">{t("services.intro")}</p>
    </div>
  </section>

  <!-- Service Sections -->
  {
    serviceSections.map((section) => {
      const items = t(section.itemsKey) as unknown as string[];
      return (
        <section class="service-section" id={section.anchorId}>
          <div class="service-section__container">
            <div class="service-section__header">
              <span class="service-section__number">{section.number}</span>
              <h2 class="service-section__title">{t(section.titleKey)}</h2>
            </div>
            <div class="service-section__content">
              <div class="service-section__image">
                <div class="service-section__image-placeholder" />
              </div>
              <div class="service-section__description">
                <p>{t(section.descriptionKey)}</p>
              </div>
            </div>
            <div class="service-section__services">
              <h3 class="service-section__services-title">
                {t("services.providedServices")}
              </h3>
              <ul class="service-section__services-list">
                {items.map((item: string) => (
                  <li class="service-section__services-item">{item}</li>
                ))}
              </ul>
            </div>
            <div class="service-section__action">
              <Button href={`/${lang}/contact/`} variant="solid" size="medium">
                {t("services.consultButton")}
              </Button>
            </div>
          </div>
        </section>
      );
    })
  }

  <!-- FAQ Section -->
  <section class="faq">
    <div class="faq__container">
      <div class="faq__header">
        <h2 class="faq__title">FAQ</h2>
        <p class="faq__subtitle">{t("services.faq.title")}</p>
      </div>
      <div class="faq__list">
        {
          faqItems.map((item, index) => (
            <details class="faq__item" open={index === 0}>
              <summary class="faq__question">
                <span class="faq__question-text">{item.question}</span>
                <span class="faq__question-icon" aria-hidden="true" />
              </summary>
              <div class="faq__answer">
                <p>{item.answer}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  .services-intro {
    padding: 2rem 1.5rem 3rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 3rem 2rem 4rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__text {
      font-size: 0.9rem;
      line-height: 2;
      color: var(--c-text-sub);
      max-width: 900px;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  .service-section {
    padding: 4rem 1.5rem;
    border-bottom: 1px solid var(--c-border-light);

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__number {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--c-text-light);
      margin-bottom: 0.5rem;
    }

    &__title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0;
      line-height: 1.4;

      @media (min-width: 768px) {
        font-size: 1.8rem;
      }
    }

    &__content {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        grid-template-columns: 280px 1fr;
        gap: 2.5rem;
        align-items: start;
        margin-bottom: 3rem;
      }
    }

    &__image {
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;

      @media (min-width: 768px) {
        aspect-ratio: 1 / 1;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }

    &__description {
      p {
        font-size: 0.9rem;
        line-height: 1.9;
        color: var(--c-text-sub);
        margin: 0;

        @media (min-width: 768px) {
          font-size: 0.95rem;
        }
      }
    }

    &__services {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__services-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 1.25rem 0;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--c-border-light);
    }

    &__services-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      list-style: none;
      padding: 0;
      margin: 0;

      @media (min-width: 640px) {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem 2rem;
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    &__services-item {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      line-height: 1.6;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--c-border-light);
    }

    &__action {
      margin-top: 0.5rem;
    }
  }

  .faq {
    padding: 4rem 1.5rem;
    background: var(--c-bg);

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
    }

    &__item {
      border: 1px solid var(--c-border);
      border-radius: 20px;
      margin-bottom: -1px;

      &[open] {
        .faq__question-icon {
          &::after {
            transform: rotate(0deg);
          }
        }
      }
    }

    &__question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 1.5rem;
      cursor: pointer;
      list-style: none;
      user-select: none;
      transition: background-color var(--transition-fast);

      &:hover {
        background-color: var(--c-bg-secondary);
      }

      &::-webkit-details-marker {
        display: none;
      }

      &::marker {
        display: none;
        content: "";
      }
    }

    &__question-text {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--c-text);
      line-height: 1.6;
      padding-right: 1rem;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__question-icon {
      position: relative;
      flex-shrink: 0;
      width: 20px;
      height: 20px;

      &::before,
      &::after {
        content: "";
        position: absolute;
        background: var(--c-text);
        transition: transform var(--transition-base);
      }

      &::before {
        top: 50%;
        left: 0;
        width: 100%;
        height: 1.5px;
        transform: translateY(-50%);
      }

      &::after {
        top: 0;
        left: 50%;
        width: 1.5px;
        height: 100%;
        transform: translateX(-50%) rotate(90deg);
      }
    }

    &__answer {
      padding: 0 1.5rem 1.25rem;

      p {
        font-size: 0.875rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin: 0;

        @media (min-width: 768px) {
          font-size: 0.9rem;
        }
      }
    }
  }
</style>
