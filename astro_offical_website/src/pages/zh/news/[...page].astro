---
import NewsListTemplate from "../../../templates/NewsListTemplate.astro";
import { getCollection } from "astro:content";
import { SITE_CONFIG } from "../../../config/site";
import type { PaginateFunction } from "astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allNews = await getCollection("news", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  const sortedNews = allNews.sort((a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf()
  );

  return paginate(sortedNews, { pageSize: SITE_CONFIG.pagination.newsPageSize });
}

const { page } = Astro.props;
---
<NewsListTemplate lang="zh" page={page} />
