---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Contact from "../../components/Contact.astro";
import WorkCard from "../../components/WorkCard.astro";
import NewsCard from "../../components/NewsCard.astro";
import Hero from "./home/hero.astro";
import Partners from "./home/partners.astro";
import Service from "./home/service.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("site.title")}>
  <Hero />
  <Partners />
  <Service />

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <h2 class="section-title">{t("works.title")}</h2>
      <p class="works__subtitle">{t("works.subtitle")}</p>
      <div class="works__grid">
        <WorkCard
          tag="网站与应用开发"
          title="电商平台重新设计"
          category="时尚品牌"
          description="对大型时尚零售商的在线商店进行全面改版。通过优化UI/UX，转化率提高40%。"
          link="/works/ec-platform-redesign"
        />
        <WorkCard
          tag="UI/UX设计"
          title="企业品牌建设"
          category="科技初创公司"
          description="对科技初创公司进行全面品牌更新。进行了标志设计、风格指南和营销资料的制作。"
          link="/works/corporate-branding"
        />
        <WorkCard
          tag="移动应用开发"
          title="移动银行应用"
          category="金融机构"
          description="拥有10万多活跃用户的安全直观的移动银行应用。提供无缝的交易体验。"
          link="/works/mobile-banking-app"
        />
        <WorkCard
          tag="数字战略"
          title="SaaS仪表板平台"
          category="企业"
          description="面向企业客户的高级分析仪表板。实现了实时数据可视化和自定义报告功能。"
          link="/works/saas-dashboard-platform"
        />
      </div>
      <a href="/works/" class="works__link">{t("works.viewAll")}</a>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <h2 class="section-title">{t("about.title")}</h2>
      <p class="about__subtitle">{t("about.subtitle")}</p>
      <div class="about__content">
        <p>
          {t("about.description")}
        </p>
      </div>
      <a href="/about/" class="about__link">{t("about.viewMore")}</a>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <h2 class="section-title">{t("news.title")}</h2>
      <p class="news__subtitle">{t("news.subtitle")}</p>
      <div class="news__grid">
        <NewsCard
          date="2025.1.15"
          type="新闻"
          title="Markdown 样式指南 - 所有显示元素的示例"
          link="/news/2025-01-15-markdown-guide"
        />
        <NewsCard
          date="2024.12.15"
          type="新闻稿"
          title="发布面向企业的 AI 驱动分析平台"
          link="/news/2024-12-15-ai-platform-release"
        />
        <NewsCard
          date="2024.11.28"
          type="新闻"
          title="五名资深开发者加入团队以加强技术实力"
          link="/news/2024-11-28-team-expansion"
        />
      </div>
      <a href="/news/" class="news__link">{t("news.viewAll")}</a>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .works {
    background: var(--c-bg-secondary);
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 2rem;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .about {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        margin-bottom: 2rem;
      }
    }

    &__content {
      max-width: 700px;
      margin: 1.5rem auto;

      @media (min-width: 768px) {
        margin: 2rem auto;
      }

      p {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin: 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      margin-top: 1.5rem;
      transition: color 0.3s;

      @media (min-width: 768px) {
        margin-top: 2rem;
      }

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .news {
    background: var(--c-bg-secondary);
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .section-title {
    text-align: center;
    font-size: 1.8rem;
    margin: 0 0 0.5rem 0;
    color: var(--c-text);

    @media (min-width: 768px) {
      font-size: 2.5rem;
    }
  }
</style>
