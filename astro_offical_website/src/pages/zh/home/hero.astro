---

<!-- Hero Section -->
<section class="hero">
  <div class="hero__container">
    <h1 class="hero__title">
      <span>体験をデザインし、</span>
      <span>未来を創造する</span>
    </h1>
    <div class="hero__image">
      <div class="hero__image-placeholder"></div>
    </div>
  </div>
</section>

<style lang="scss">
  .hero {
    padding: 4rem 1.5rem 3rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem 4rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.4;
      color: var(--c-text);
      margin: 0 0 2rem 0;

      span {
        display: block;
      }

      @media (min-width: 640px) {
        font-size: 2.5rem;
      }

      @media (min-width: 768px) {
        font-size: 3.5rem;
        margin: 0 0 3rem 0;
      }
    }

    &__image {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      overflow: hidden;

      @media (min-width: 768px) {
        aspect-ratio: 2.5 / 1;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%);
    }
  }
</style>
