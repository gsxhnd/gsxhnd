---
import Layout from "../layouts/Layout.astro";
import { SITE_CONFIG } from "../config/site";
---

<Layout title={`公司概览 | ${SITE_CONFIG.company.name}`}>
  <section class="page-header">
    <div class="page-header__container">
      <h1>公司概览</h1>
    </div>
  </section>

  <section class="page-content">
    <div class="page-content__container">
      <div class="company-overview">
        <div class="company-info__item">
          <div class="info-label">公司名称</div>
          <div class="info-value">{SITE_CONFIG.company.name}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">成立</div>
          <div class="info-value">{SITE_CONFIG.company.established}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">总部地点</div>
          <div class="info-value" set:html={SITE_CONFIG.company.address.replace(/\n/g, '<br />')} />
        </div>

        <div class="company-info__item">
          <div class="info-label">电话号码</div>
          <div class="info-value"><a href={`tel:${SITE_CONFIG.company.phone}`}>{SITE_CONFIG.company.phoneDisplay}</a></div>
        </div>

        <div class="company-info__item">
          <div class="info-label">电子邮件地址</div>
          <div class="info-value"><a href={`mailto:${SITE_CONFIG.company.email}`}>{SITE_CONFIG.company.emailDisplay}</a></div>
        </div>

        <div class="company-info__item">
          <div class="info-label">营业时间</div>
          <div class="info-value">{SITE_CONFIG.company.businessHoursFull}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">代表董事</div>
          <div class="info-value">{SITE_CONFIG.company.ceo}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">员工数</div>
          <div class="info-value">{SITE_CONFIG.company.employees}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">资本</div>
          <div class="info-value">{SITE_CONFIG.company.capital}</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">主要业务内容</div>
          <div class="info-value">
            <ul>
              {SITE_CONFIG.businessContent.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="company-info__item">
          <div class="info-label">获得资格和认证</div>
          <div class="info-value">
            <ul>
              {SITE_CONFIG.certifications.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .page-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 2rem 1.5rem;
    text-align: center;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;

      h1 {
        font-size: 2rem;
        margin: 0;

        @media (min-width: 768px) {
          font-size: 2.5rem;
        }
      }
    }
  }

  .page-content {
    padding: 2rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      a {
        color: var(--c-primary);
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }
  }

  .company-overview {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    @media (min-width: 768px) {
      gap: 2rem;
    }
  }

  .company-info__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e6e6e6;

    @media (min-width: 600px) {
      grid-template-columns: 180px 1fr;
      gap: 1.5rem;
      padding-bottom: 2rem;
    }

    @media (min-width: 900px) {
      grid-template-columns: 220px 1fr;
      gap: 2rem;
      padding-bottom: 2.5rem;
    }

    &:last-child {
      border-bottom: none;
    }
  }

  .info-label {
    color: #666666;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.5;

    @media (min-width: 900px) {
      font-size: 1rem;
    }
  }

  .info-value {
    color: #222222;
    font-size: 0.875rem;
    line-height: 1.6;

    @media (min-width: 900px) {
      font-size: 1rem;
    }

    ul {
      margin: 0;
      padding-left: 1.25rem;
      list-style: disc;

      @media (min-width: 900px) {
        padding-left: 1.5rem;
      }

      li {
        margin-bottom: 0.5rem;
      }
    }

    a {
      color: var(--c-primary);
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
