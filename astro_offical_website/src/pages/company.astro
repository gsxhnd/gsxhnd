---
import Layout from "../layouts/Layout.astro";
---

<Layout title="公司概览 | CName Inc.">
  <section class="page-header">
    <div class="page-header__container">
      <h1>公司概览</h1>
    </div>
  </section>

  <section class="page-content">
    <div class="page-content__container">
      <div class="company-overview">
        <div class="company-info__item">
          <div class="info-label">公司名称</div>
          <div class="info-value">CName Inc.</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">成立</div>
          <div class="info-value">2019年4月1日</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">总部地点</div>
          <div class="info-value">123123<br />123123</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">电话号码</div>
          <div class="info-value"><a href="tel:+81-3-xxxx-xxxx">+81-3-XXXX-XXXX</a></div>
        </div>

        <div class="company-info__item">
          <div class="info-label">电子邮件地址</div>
          <div class="info-value"><a href="mailto:info@CName.jp">xxx@xxx</a></div>
        </div>

        <div class="company-info__item">
          <div class="info-label">营业时间</div>
          <div class="info-value">周一至周五 9:00 - 18:00（周末和假日休息）</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">代表董事</div>
          <div class="info-value">123</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">员工数</div>
          <div class="info-value">35名（截至2024年12月末）</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">资本</div>
          <div class="info-value">1万</div>
        </div>

        <div class="company-info__item">
          <div class="info-label">主要业务内容</div>
          <div class="info-value">
            <ul>
              <li>Web网站・Web应用开发</li>
              <li>移动应用开发</li>
              <li>UI/UX设计</li>
              <li>品牌咨询</li>
              <li>数字营销支持</li>
            </ul>
          </div>
        </div>

        <div class="company-info__item">
          <div class="info-label">获得资格和认证</div>
          <div class="info-value">
            <ul>
              <li>信息安全管理系统认证 (ISO 27001)</li>
              <li>Google Partner</li>
              <li>AWS Partner</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .page-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 2rem 1.5rem;
    text-align: center;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;

      h1 {
        font-size: 2rem;
        margin: 0;

        @media (min-width: 768px) {
          font-size: 2.5rem;
        }
      }
    }
  }

  .page-content {
    padding: 2rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      a {
        color: var(--c-primary);
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }
  }

  .company-overview {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    @media (min-width: 768px) {
      gap: 2rem;
    }
  }

  .company-info__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e6e6e6;

    @media (min-width: 600px) {
      grid-template-columns: 180px 1fr;
      gap: 1.5rem;
      padding-bottom: 2rem;
    }

    @media (min-width: 900px) {
      grid-template-columns: 220px 1fr;
      gap: 2rem;
      padding-bottom: 2.5rem;
    }

    &:last-child {
      border-bottom: none;
    }
  }

  .info-label {
    color: #666666;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.5;

    @media (min-width: 900px) {
      font-size: 1rem;
    }
  }

  .info-value {
    color: #222222;
    font-size: 0.875rem;
    line-height: 1.6;

    @media (min-width: 900px) {
      font-size: 1rem;
    }

    ul {
      margin: 0;
      padding-left: 1.25rem;
      list-style: disc;

      @media (min-width: 900px) {
        padding-left: 1.5rem;
      }

      li {
        margin-bottom: 0.5rem;
      }
    }

    a {
      color: var(--c-primary);
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
