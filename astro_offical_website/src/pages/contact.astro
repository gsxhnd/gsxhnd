---
import Layout from "../layouts/Layout.astro";
import { SITE_CONFIG } from "../config/site";
---

<Layout title={`Contact | ${SITE_CONFIG.name}`}>
  <!-- Page Header -->
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">Contact</h1>
      <p class="page-header__subtitle">お問い合わせ</p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="contact-form-section">
    <div class="contact-form-section__container">
      <p class="contact-form-section__intro">
        サービスに関するご相談やお見積もりのご依頼、ご質問などお気軽にお問い合わせください。
      </p>

      <form class="contact-form" action="#" method="POST">
        <!-- Inquiry Type -->
        <div class="form-group">
          <label class="form-label">
            お問い合わせの種類
            <span class="form-required">必須</span>
          </label>
          <div class="form-radio-group">
            <label class="form-radio">
              <input type="radio" name="inquiry_type" value="project" required />
              <span class="form-radio__label">案件のご依頼やご相談</span>
            </label>
            <label class="form-radio">
              <input type="radio" name="inquiry_type" value="estimate" />
              <span class="form-radio__label">お見積もりのご依頼</span>
            </label>
            <label class="form-radio">
              <input type="radio" name="inquiry_type" value="partnership" />
              <span class="form-radio__label">協業のご提案やお問い合わせ</span>
            </label>
            <label class="form-radio">
              <input type="radio" name="inquiry_type" value="other" />
              <span class="form-radio__label">その他のお問い合わせ</span>
            </label>
          </div>
        </div>

        <!-- Inquiry Content -->
        <div class="form-group">
          <label class="form-label" for="message">
            お問い合わせ内容
            <span class="form-required">必須</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="8"
            required
            placeholder="案件の詳細、ご予算やご希望の納期など具体的にご記入いただきますと、よりスムーズなご提案が可能です。"
          ></textarea>
        </div>

        <!-- Name -->
        <div class="form-group">
          <label class="form-label" for="name">
            お名前
            <span class="form-required">必須</span>
          </label>
          <input type="text" id="name" name="name" required placeholder="山田 太郎" />
        </div>

        <!-- Furigana -->
        <div class="form-group">
          <label class="form-label" for="furigana">
            フリガナ
            <span class="form-required">必須</span>
          </label>
          <input type="text" id="furigana" name="furigana" required placeholder="ヤマダ タロウ" />
        </div>

        <!-- Company -->
        <div class="form-group">
          <label class="form-label" for="company">
            会社名
            <span class="form-required">必須</span>
          </label>
          <input type="text" id="company" name="company" required placeholder="株式会社サンプル" />
        </div>

        <!-- Email -->
        <div class="form-group">
          <label class="form-label" for="email">
            メールアドレス
            <span class="form-required">必須</span>
          </label>
          <input type="email" id="email" name="email" required placeholder="example@company.com" />
        </div>

        <!-- Phone -->
        <div class="form-group">
          <label class="form-label" for="phone">
            電話番号
            <span class="form-optional">任意</span>
          </label>
          <input type="tel" id="phone" name="phone" placeholder="03-1234-5678" />
        </div>

        <!-- Privacy Policy -->
        <div class="form-group form-group--checkbox">
          <label class="form-checkbox">
            <input type="checkbox" name="privacy" required />
            <span class="form-checkbox__label">
              <a href="/privacy/" target="_blank">個人情報保護方針</a>に同意する
            </span>
          </label>
        </div>

        <!-- Submit Button -->
        <div class="form-group form-group--submit">
          <button type="submit" class="form-submit">送信する</button>
        </div>
      </form>
    </div>
  </section>
</Layout>

<style lang="scss">
  /* Page Header */
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  /* Contact Form Section */
  .contact-form-section {
    padding: 3rem 1.5rem 4rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 4rem 2rem 6rem;
    }

    &__container {
      max-width: 700px;
      margin: 0 auto;
    }

    &__intro {
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0 0 2.5rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
        margin: 0 0 3rem 0;
      }
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--c-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .form-required {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--c-text-inverse);
    background: var(--c-primary);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }

  .form-optional {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--c-text-sub);
    background: var(--c-border);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }

  .form-radio-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .form-radio {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;

    input[type="radio"] {
      width: 18px;
      height: 18px;
      accent-color: var(--c-primary);
      cursor: pointer;
    }

    &__label {
      font-size: 0.9rem;
      color: var(--c-text);
    }
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    font-size: 0.9rem;
    font-family: inherit;
    color: var(--c-text);
    background: var(--c-bg);
    transition: border-color var(--transition-base);

    &::placeholder {
      color: var(--c-text-light);
    }

    &:focus {
      outline: none;
      border-color: var(--c-primary);
    }
  }

  textarea {
    resize: vertical;
    min-height: 160px;
  }

  .form-group--checkbox {
    margin-top: 0.5rem;
  }

  .form-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;

    input[type="checkbox"] {
      width: 18px;
      height: 18px;
      accent-color: var(--c-primary);
      cursor: pointer;
    }

    &__label {
      font-size: 0.85rem;
      color: var(--c-text-sub);

      a {
        color: var(--c-text);
        text-decoration: underline;
        transition: color var(--transition-base);

        &:hover {
          color: var(--c-primary);
        }
      }
    }
  }

  .form-group--submit {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .form-submit {
    display: inline-block;
    min-width: 240px;
    padding: 1rem 2rem;
    background: var(--c-primary);
    color: var(--c-text-inverse);
    border: none;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: background var(--transition-base);
    text-align: center;

    @media (min-width: 768px) {
      min-width: 280px;
    }

    &:hover {
      background: var(--c-primary-light);
    }

    &:active {
      transform: scale(0.98);
    }
  }
</style>
