---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import Hero from "./home/hero.astro";
import Partners from "./home/partners.astro";
import Service from "./home/service.astro";
import { getCollection } from "astro:content";
import { SITE_CONFIG } from "../config/site";

const allNews = await getCollection("news", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const sortedNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const works = [
  {
    title: "ECプラットフォーム リデザイン",
    category: "ファッションブランド",
    description: "大手ファッションリテーラーのオンラインストアを全面改修。UI/UXの最適化により、コンバージョン率が40%向上、MAUが前年比200%増加を達成。",
    link: "/works/ec-platform-redesign",
    tag: "Webサイト・アプリケーション開発",
  },
  {
    title: "コーポレート ブランディング",
    category: "テクノロジースタートアップ",
    description: "テクノロジースタートアップの包括的なブランドリニューアル。ロゴデザイン、スタイルガイド、マーケティング素材の制作を行いました。",
    link: "/works/corporate-branding",
    tag: "UI/UXデザイン",
  },
  {
    title: "モバイルバンキング アプリケーション",
    category: "金融機関",
    description: "10万人以上のアクティブユーザーを持つ安全で直感的なモバイルバンキングアプリ。シームレスな取引体験を提供しています。",
    link: "/works/mobile-banking-app",
    tag: "モバイルアプリ開発",
  },
  {
    title: "SaaSダッシュボード プラットフォーム",
    category: "エンタープライズ",
    description: "エンタープライズ向けの高度な分析ダッシュボード。リアルタイムデータ可視化とカスタムレポーティング機能を実装しました。",
    link: "/works/saas-dashboard-platform",
    tag: "デジタル戦略",
  },
];
---

<Layout title={SITE_CONFIG.title}>
  <Hero />
  <Partners />
  <Service />

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <div class="works__header">
        <h2 class="works__title">Works</h2>
        <p class="works__subtitle">制作実績</p>
        <a href="/works/" class="works__link">一覧を見る →</a>
      </div>
      <div class="works__list">
        {works.map((work) => (
          <a href={work.link} class="work-item">
            <div class="work-item__image">
              <div class="work-item__image-placeholder"></div>
            </div>
            <div class="work-item__content">
              <h3 class="work-item__title">{work.title}</h3>
              <p class="work-item__description">{work.description}</p>
              <span class="work-item__link">詳細を見る →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <div class="about__header">
        <h2 class="about__title">About</h2>
        <p class="about__subtitle">私たちについて</p>
      </div>
      <div class="about__content">
        <p>
          私たちは、デザインとテクノロジーの力で、<br />
          ブランドの本質を引き出し、新しい価値を生み出します。
        </p>
        <p>
          戦略的な思考と緻密なクラフトマンシップで、<br />
          ユーザーの心に響く体験を設計し、<br />
          ビジネスの成長を加速させるデジタルソリューションを提供します。
        </p>
        <p>
          一つひとつのプロジェクトに真摯に向き合い、<br />
          クライアントと共に未来を描いていく。<br />
          それが私たちのスタイルです。
        </p>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <div class="news__header">
        <div class="news__header-left">
          <h2 class="news__title">News</h2>
          <p class="news__subtitle">お知らせ</p>
        </div>
        <a href="/news/" class="news__link">一覧を見る →</a>
      </div>
      <div class="news__list">
        {sortedNews.map((entry) => (
          <a href={`/news/${entry.id}`} class="news-item">
            <time class="news-item__date">
              {entry.data.date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".")}
            </time>
            <span class="news-item__type">{entry.data.type || "お知らせ"}</span>
            <span class="news-item__title">{entry.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  /* Works Section */
  .works {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        margin-bottom: 3.5rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0 0 0.75rem 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color var(--transition-base);

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 3rem;

      @media (min-width: 768px) {
        gap: 4rem;
      }
    }
  }

  .work-item {
    display: block;
    text-decoration: none;
    color: inherit;

    &__image {
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        aspect-ratio: 16 / 9;
        max-width: 800px;
        margin-left: auto;
        margin-right: 0;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }

    &__content {
      @media (min-width: 768px) {
        max-width: 600px;
      }
    }

    &__title {
      font-size: 1.2rem;
      font-weight: 600;
      margin: 0 0 0.75rem 0;
      color: var(--c-text);

      @media (min-width: 768px) {
        font-size: 1.4rem;
      }
    }

    &__description {
      font-size: 0.875rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0 0 1rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      transition: color var(--transition-base);
    }

    &:hover &__link {
      color: var(--c-text);
    }
  }

  /* About Section */
  .about {
    padding: 4rem 1.5rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__content {
      max-width: 700px;

      p {
        font-size: 0.95rem;
        line-height: 2;
        color: var(--c-text-sub);
        margin: 0 0 1.5rem 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }

        &:last-child {
          margin-bottom: 0;
        }
      }
    }
  }

  /* News Section */
  .news {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__header-left {
      // intentionally empty for grouping
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color var(--transition-base);
      white-space: nowrap;

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--c-border);
    }
  }

  .news-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-base);

    @media (min-width: 768px) {
      grid-template-columns: 100px 80px 1fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 0;
    }

    &:hover {
      opacity: 0.7;
    }

    &__date {
      font-size: 0.8rem;
      color: var(--c-text-light);
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.15rem 0.5rem;
      border-radius: 2px;
      font-weight: 500;
      width: fit-content;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    &__title {
      font-size: 0.9rem;
      color: var(--c-text);
      font-weight: 400;
      line-height: 1.5;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }
</style>
