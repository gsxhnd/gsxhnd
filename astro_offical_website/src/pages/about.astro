---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";
import { SITE_CONFIG } from "../config/site";

const teamMembers = [
  { name: "井上 優介", role: "Creative Director", image: "" },
  { name: "高橋 亜紀", role: "Lead Designer", image: "" },
  { name: "松田 真希", role: "Frontend Developer", image: "" },
  { name: "久保 悠斗", role: "UI/UX Designer", image: "" },
  { name: "岡田 真輝", role: "Backend Developer", image: "" },
  { name: "Bob", role: "Chief of Security", image: "" },
];
---

<Layout title={`About Us | ${SITE_CONFIG.name}`}>
  <!-- Page Header -->
  <section class="page-header">
    <div class="page-header__container">
      <h1 class="page-header__title">About Us</h1>
      <p class="page-header__subtitle">私たちについて</p>
    </div>
  </section>

  <!-- Strengths Section -->
  <section class="strengths">
    <div class="strengths__container">
      <div class="strengths__item">
        <div class="strengths__text">
          <h2 class="strengths__heading">私たちの強み</h2>
          <p class="strengths__description">
            デザインとテクノロジーの融合により、ユーザー体験を最大化するデジタルプロダクトを創出します。戦略立案から設計、開発、運用まで、一貫したサポートを提供し、お客様のビジネス成長に貢献します。
          </p>
        </div>
        <div class="strengths__image">
          <div class="strengths__image-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technology Section -->
  <section class="technology">
    <div class="technology__container">
      <div class="technology__image">
        <div class="technology__image-placeholder"></div>
      </div>
      <div class="technology__text">
        <h2 class="technology__heading">技術へのこだわり</h2>
        <p class="technology__description">
          最新のWeb技術とベストプラクティスを活用し、パフォーマンス、アクセシビリティ、SEOに優れたプロダクトを開発します。常に学び続け、技術の進歩に柔軟に対応できるチーム体制を構築しています。
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="values">
    <div class="values__container">
      <div class="values__header">
        <h2 class="values__title">Our Values</h2>
        <p class="values__subtitle">私たちが選ばれる理由</p>
      </div>
      <div class="values__list">
        <div class="values__item">
          <h3 class="values__item-title">ユーザー中心の体験設計</h3>
          <p class="values__item-description">
            私たちはすべてのプロジェクトにおいて、ユーザーの視点を最も重要視しています。単に美しいデザインを作るだけでなく、実際に使いやすく、直感的な操作を実現するために、綿密なリサーチとテストを行います。すべてのプロジェクトの出発点は、ビジネスの成功を、本質的なリサーチから始めます。
          </p>
        </div>
        <div class="values__item">
          <h3 class="values__item-title">戦略とデザインの統合</h3>
          <p class="values__item-description">
            美しいだけのデザインでは終わりません。ビジネスゴールから逆算し、データを基に最適なUI/UXを設計します。チーム全体がブランディングからUIまで一貫して担当し、戦略設計からデザイン実装までの一つの流れとして捉え、統合的にプロジェクトを推進します。
          </p>
        </div>
        <div class="values__item">
          <h3 class="values__item-title">最新技術と品質へのこだわり</h3>
          <p class="values__item-description">
            最新のフレームワークやツールを積極的に導入し、プロジェクトに最適な技術を選定します。パフォーマンス、セキュリティ、保守性を重視した開発を行い、長期的に安定して運用できるプロダクトをお届けします。
          </p>
        </div>
        <div class="values__item">
          <h3 class="values__item-title">スピードと柔軟性</h3>
          <p class="values__item-description">
            アジャイルな開発プロセスにより、変化の激しい市場環境でも品質を両立します。フィードバックを迅速に取り入れ反映する迅速な対応と、最終的なクオリティの高さを両立させるプロフェッショナルな体制です。
          </p>
        </div>
        <div class="values__item">
          <h3 class="values__item-title">共創するパートナーシップ</h3>
          <p class="values__item-description">
            クライアントの単なるリソースではなく、共に未来を創るパートナーとして、プロジェクトに取り組みます。長期的な関係構築を大切にし、ビジネスの成長に寄り添ったソリューションを提供し続けます。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CEO Message Section -->
  <section class="ceo-message">
    <div class="ceo-message__container">
      <div class="ceo-message__header">
        <h2 class="ceo-message__title">Message from CEO</h2>
        <p class="ceo-message__subtitle">代表メッセージ</p>
      </div>
      <div class="ceo-message__content">
        <div class="ceo-message__photo">
          <div class="ceo-message__photo-placeholder"></div>
        </div>
        <div class="ceo-message__text">
          <h3 class="ceo-message__heading">未来の当たり前を、静かに大胆に。</h3>
          <p>
            私たちの仕事は、企業とユーザーの間にある"体験の壁"を取り除くこと。もっと直感的で、もっと美しいデジタル体験を。
          </p>
          <p>
            テクノロジーが急速に進化する中で、時代に振り回されることなく、一人ひとりの体感に寄り添った"丁寧な挑戦"をつづけていきたいと考えています。
          </p>
          <p>
            クライアントと共に課題と向き合い、小さな実験を積み重ねることで確かな価値を生み出す。それこそがパートナーシップだと、私たちは考えます。
          </p>
          <p>
            そんな想いを胸に、これからも価値ある未来づくりに取り組んでいきます。
          </p>
          <div class="ceo-message__signature">
            <span class="ceo-message__role">{SITE_CONFIG.company.ceoTitle} {SITE_CONFIG.company.ceo}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team">
    <div class="team__container">
      <div class="team__header">
        <h2 class="team__title">Meet Our Team</h2>
        <p class="team__subtitle">チームメンバー</p>
      </div>
      <p class="team__description">
        私たちは東京、大阪、福岡の3拠点を軸に、デザインとテクノロジーの力で、クライアントのビジネス成長を支援しています。各メンバーがそれぞれの専門性を持ち、複雑なデジタル体験を創出することに情熱を注いでいます。お客様のビジョンを実現するために、常に学び、挑戦し続けるチームです。
      </p>
      <div class="team__grid">
        {teamMembers.map((member) => (
          <div class="team__member">
            <div class="team__member-photo">
              <div class="team__member-photo-placeholder"></div>
            </div>
            <p class="team__member-name">{member.name}</p>
            <p class="team__member-role">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  /* Page Header */
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }

  /* Strengths Section */
  .strengths {
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__item {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
      }
    }

    &__heading {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 1rem 0;

      @media (min-width: 768px) {
        font-size: 1.8rem;
      }
    }

    &__description {
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__image {
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }
  }

  /* Technology Section */
  .technology {
    padding: 3rem 1.5rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 4rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
      }
    }

    &__image {
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #e8e4de 0%, #d4cfc7 100%);
    }

    &__heading {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 1rem 0;

      @media (min-width: 768px) {
        font-size: 1.8rem;
      }
    }

    &__description {
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  /* Values Section */
  .values {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 3rem;

      @media (min-width: 768px) {
        margin-bottom: 4rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;

      @media (min-width: 768px) {
        gap: 3rem;
        padding-left: 2rem;
        border-left: 1px solid var(--c-border);
      }
    }

    &__item {
      max-width: 700px;
    }

    &__item-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 0.75rem 0;

      @media (min-width: 768px) {
        font-size: 1.2rem;
      }
    }

    &__item-description {
      font-size: 0.875rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  /* CEO Message Section */
  .ceo-message {
    padding: 4rem 1.5rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__content {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: 200px 1fr;
        gap: 3rem;
      }
    }

    &__photo {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;

      @media (min-width: 768px) {
        width: 200px;
        height: 200px;
      }
    }

    &__photo-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-border);
    }

    &__heading {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 1.5rem 0;

      @media (min-width: 768px) {
        font-size: 1.3rem;
      }
    }

    &__text {
      p {
        font-size: 0.875rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin: 0 0 1rem 0;

        @media (min-width: 768px) {
          font-size: 0.95rem;
        }
      }
    }

    &__signature {
      margin-top: 1.5rem;
    }

    &__role {
      font-size: 0.85rem;
      color: var(--c-text);
      font-weight: 500;
    }
  }

  /* Team Section */
  .team {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        margin-bottom: 2rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__description {
      font-size: 0.875rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      max-width: 800px;
      margin: 0 0 3rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;

      @media (min-width: 640px) {
        grid-template-columns: repeat(3, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(4, 1fr);
        gap: 2.5rem;
      }
    }

    &__member {
      text-align: center;
    }

    &__member-photo {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto 1rem;

      @media (min-width: 768px) {
        width: 150px;
        height: 150px;
      }
    }

    &__member-photo-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }

    &__member-name {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;
    }

    &__member-role {
      font-size: 0.8rem;
      color: var(--c-text-sub);
      margin: 0;
    }
  }
</style>
