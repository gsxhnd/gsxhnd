---
const partners = [
  "Nagi co.jp partner",
  "CorporateX",
  "LoopStorm",
  "Loopstream",
  "LOGOPIA",
  "Corpstream",
  "Corpstream",
];
---

<section class="partners">
  <div class="partners__container">
    <p class="partners__title">さまざまな業界のクライアント様とパートナーシップを築いています</p>
    <div class="partners__track">
      {partners.map((name) => (
        <div class="partners__item">
          <span class="partners__logo">{name}</span>
        </div>
      ))}
      {partners.map((name) => (
        <div class="partners__item" aria-hidden="true">
          <span class="partners__logo">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .partners {
    padding: 2.5rem 1.5rem;
    border-top: 1px solid var(--c-border-light);
    border-bottom: 1px solid var(--c-border-light);
    overflow: hidden;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__title {
      text-align: center;
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0 0 2rem 0;
      letter-spacing: 0.02em;

      @media (min-width: 768px) {
        font-size: 0.95rem;
        margin: 0 0 2.5rem 0;
      }
    }

    &__track {
      display: flex;
      gap: 2rem;
      animation: scroll 30s linear infinite;
      width: fit-content;

      @media (min-width: 768px) {
        gap: 3rem;
      }
    }

    &__item {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 1rem;
    }

    &__logo {
      font-size: 0.85rem;
      color: var(--c-text-light);
      white-space: nowrap;
      font-weight: 500;
      letter-spacing: 0.05em;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
