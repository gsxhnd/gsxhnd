<!-- Hero Section -->
<section class="hero">
  <div class="hero__container">
    <span class="hero__title"> 设计体验， </span>
    <span class="hero__title"> 创造未来 </span>
  </div>
</section>

<style lang="scss">
  .hero {
    // background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: rgb(16, 16, 16);
    padding: 4rem 1.5rem;
    text-align: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
      min-height: 500px;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }

    &__title {
      font-size: 2rem;
      margin: 0 0 1.5rem 0;
      line-height: 1.3;
      font-weight: 700;

      @media (min-width: 640px) {
        font-size: 2.5rem;
      }

      @media (min-width: 768px) {
        font-size: 3.5rem;
      }
    }

    &__subtitle {
      font-size: 1rem;
      margin: 0 0 2rem 0;
      opacity: 0.95;

      @media (min-width: 768px) {
        font-size: 1.2rem;
      }
    }

    &__cta {
      display: inline-block;
      background: white;
      color: #667eea;
      padding: 0.8rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 600;
      transition:
        transform 0.3s,
        box-shadow 0.3s;
      font-size: 0.9rem;

      @media (min-width: 768px) {
        padding: 1rem 2.5rem;
        font-size: 1rem;
      }

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      }
    }
  }
</style>
