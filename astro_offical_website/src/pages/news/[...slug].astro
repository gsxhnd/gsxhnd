---
import Layout from "../../layouts/Layout.astro";
import Contact from "../../components/Contact.astro";
import { getCollection, render } from "astro:content";
import { SITE_CONFIG } from "../../config/site";

export async function getStaticPaths() {
  const allNews = await getCollection("news", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  return allNews.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | ${SITE_CONFIG.name}`}>
  <section class="page-header">
    <div class="page-header__container">
      <div class="page-header__breadcrumb">
        <a href="/news/" class="page-header__back">News</a>
        <span class="page-header__separator">/</span>
        <span class="page-header__current">記事</span>
      </div>
      <div class="page-header__meta">
        <time class="page-header__date">
          {entry.data.date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".")}
        </time>
        {entry.data.type && <span class="page-header__type">{entry.data.type}</span>}
      </div>
      <h1 class="page-header__title">{entry.data.title}</h1>
    </div>
  </section>

  <article class="news-detail">
    <div class="news-detail__container">
      <Content />
    </div>
  </article>

  <div class="news-back">
    <a href="/news/" class="news-back__link">← お知らせ一覧に戻る</a>
  </div>

  <Contact />
</Layout>

<style lang="scss">
  .page-header {
    padding: 3rem 1.5rem 2rem;

    @media (min-width: 768px) {
      padding: 4rem 2rem 3rem;
    }

    &__container {
      max-width: 800px;
      margin: 0 auto;
    }

    &__breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.8rem;
      color: var(--c-text-sub);
    }

    &__back {
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }

    &__separator {
      color: var(--c-text-lightest, #ccc);
    }

    &__current {
      color: var(--c-text-light);
    }

    &__meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    &__date {
      font-size: 0.85rem;
      color: var(--c-text-light);
      font-weight: 500;
    }

    &__type {
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      font-weight: 500;
    }

    &__title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0;
      line-height: 1.4;

      @media (min-width: 768px) {
        font-size: 2rem;
      }
    }
  }

  .news-detail {
    padding: 2rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 3rem 2rem;
    }

    &__container {
      :global(h2) {
        font-size: 1.3rem;
        margin: 1.5rem 0 0.8rem;
        color: var(--c-text);
        font-weight: 600;

        @media (min-width: 768px) {
          font-size: 1.5rem;
          margin: 2rem 0 1rem;
        }
      }

      :global(h3) {
        font-size: 1.1rem;
        margin: 1rem 0 0.6rem;
        color: var(--c-text);
        font-weight: 600;

        @media (min-width: 768px) {
          font-size: 1.2rem;
          margin: 1.5rem 0 0.8rem;
        }
      }

      :global(p) {
        color: var(--c-text-sub);
        line-height: 1.8;
        margin-bottom: 1rem;
        font-size: 0.9rem;

        @media (min-width: 768px) {
          margin-bottom: 1.5rem;
          font-size: 0.95rem;
        }
      }

      :global(ul),
      :global(ol) {
        margin: 0 0 1rem 1.2rem;
        color: var(--c-text-sub);
        list-style: disc;

        @media (min-width: 768px) {
          margin: 0 0 1.5rem 1.5rem;
        }

        :global(li) {
          margin-bottom: 0.5rem;
          line-height: 1.6;
          font-size: 0.9rem;

          @media (min-width: 768px) {
            font-size: 0.95rem;
          }
        }
      }

      :global(code) {
        background: var(--c-bg-secondary);
        padding: 0.2rem 0.5rem;
        border-radius: 3px;
        font-family: "Courier New", Courier, monospace;
        font-size: 0.85rem;
      }

      :global(pre) {
        background: var(--c-bg-secondary);
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1rem;

        @media (min-width: 768px) {
          padding: 1.5rem;
          margin-bottom: 1.5rem;
        }

        :global(code) {
          background: none;
          padding: 0;
          color: var(--c-text);
        }
      }

      :global(blockquote) {
        border-left: 3px solid var(--c-border);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--c-text-sub);
        font-size: 0.9rem;

        @media (min-width: 768px) {
          padding-left: 1.5rem;
          margin: 1.5rem 0;
        }
      }

      :global(a) {
        color: var(--c-text);
        text-decoration: underline;
        transition: opacity 0.2s ease;

        &:hover {
          opacity: 0.7;
        }
      }

      :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.85rem;

        @media (min-width: 768px) {
          margin: 1.5rem 0;
          font-size: 0.95rem;
        }

        :global(th),
        :global(td) {
          border: 1px solid var(--c-border-light);
          padding: 0.5rem;
          text-align: left;

          @media (min-width: 768px) {
            padding: 0.75rem;
          }
        }

        :global(th) {
          background: var(--c-bg-secondary);
          font-weight: 600;
        }
      }
    }
  }

  .news-back {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;

    @media (min-width: 768px) {
      padding: 0 2rem 6rem;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }
  }
</style>
