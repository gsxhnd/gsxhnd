---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Contact from "../../components/Contact.astro";
import Hero from "../home/hero.astro";
import Partners from "../home/partners.astro";
import Service from "../home/service.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { SITE_CONFIG } from "../../config/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allNews = await getCollection("news", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const sortedNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const works = [
  {
    title: "E-commerce Platform Redesign",
    category: "Fashion Brand",
    description: "Complete overhaul of an online store for a major fashion retailer. Improved conversion rates by 40% through optimized UI/UX, with MAU increasing 200% year-over-year.",
    link: "/en/works/ec-platform-redesign",
    tag: "Website & App Development",
  },
  {
    title: "Corporate Branding",
    category: "Tech Startup",
    description: "Comprehensive brand refresh for a tech startup. Created logo design, style guide, and marketing materials to establish a strong visual identity.",
    link: "/en/works/corporate-branding",
    tag: "UI/UX Design",
  },
  {
    title: "Mobile Banking Application",
    category: "Financial Institution",
    description: "Secure and intuitive mobile banking app with over 100,000 active users. Provides seamless transaction experience with cutting-edge security.",
    link: "/en/works/mobile-banking-app",
    tag: "Mobile App Development",
  },
  {
    title: "SaaS Dashboard Platform",
    category: "Enterprise",
    description: "Advanced analytics dashboard for enterprise clients. Implemented real-time data visualization and custom reporting features for data-driven decisions.",
    link: "/en/works/saas-dashboard-platform",
    tag: "Digital Strategy",
  },
];
---

<Layout title={t('site.title')}>
  <Hero />
  <Partners />
  <Service />

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <div class="works__header">
        <h2 class="works__title">Works</h2>
        <p class="works__subtitle">Our Projects</p>
        <a href="/en/works/" class="works__link">View All →</a>
      </div>
      <div class="works__list">
        {works.map((work) => (
          <a href={work.link} class="work-item">
            <div class="work-item__image">
              <div class="work-item__image-placeholder"></div>
            </div>
            <div class="work-item__content">
              <h3 class="work-item__title">{work.title}</h3>
              <p class="work-item__description">{work.description}</p>
              <span class="work-item__link">View Details →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <div class="about__header">
        <h2 class="about__title">About</h2>
        <p class="about__subtitle">About Us</p>
      </div>
      <div class="about__content">
        <p>
          We unlock brand essence and create new value<br />
          through the power of design and technology.
        </p>
        <p>
          With strategic thinking and meticulous craftsmanship,<br />
          we design experiences that resonate with users<br />
          and provide digital solutions that accelerate business growth.
        </p>
        <p>
          We approach every project with sincerity<br />
          and envision the future together with our clients.<br />
          That is our style.
        </p>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <div class="news__header">
        <div class="news__header-left">
          <h2 class="news__title">News</h2>
          <p class="news__subtitle">Latest Updates</p>
        </div>
        <a href="/en/news/" class="news__link">View All →</a>
      </div>
      <div class="news__list">
        {sortedNews.map((entry) => (
          <a href={`/en/news/${entry.id}`} class="news-item">
            <time class="news-item__date">
              {entry.data.date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\//g, ".")}
            </time>
            <span class="news-item__type">{entry.data.type || "News"}</span>
            <span class="news-item__title">{entry.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  /* Works Section */
  .works {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2.5rem;

      @media (min-width: 768px) {
        margin-bottom: 3.5rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0 0 0.75rem 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 3rem;

      @media (min-width: 768px) {
        gap: 4rem;
      }
    }
  }

  .work-item {
    display: block;
    text-decoration: none;
    color: inherit;

    &__image {
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        aspect-ratio: 16 / 9;
        max-width: 800px;
        margin-left: auto;
        margin-right: 0;
      }
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background: var(--c-bg-secondary);
    }

    &__content {
      @media (min-width: 768px) {
        max-width: 600px;
      }
    }

    &__title {
      font-size: 1.2rem;
      font-weight: 600;
      margin: 0 0 0.75rem 0;
      color: var(--c-text);

      @media (min-width: 768px) {
        font-size: 1.4rem;
      }
    }

    &__description {
      font-size: 0.875rem;
      line-height: 1.8;
      color: var(--c-text-sub);
      margin: 0 0 1rem 0;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      transition: color 0.2s ease;
    }

    &:hover &__link {
      color: var(--c-text);
    }
  }

  /* About Section */
  .about {
    padding: 4rem 1.5rem;
    background: var(--c-bg-secondary);

    @media (min-width: 768px) {
      padding: 6rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      font-style: italic;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__content {
      max-width: 700px;

      p {
        font-size: 0.95rem;
        line-height: 2;
        color: var(--c-text-sub);
        margin: 0 0 1.5rem 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }

        &:last-child {
          margin-bottom: 0;
        }
      }
    }
  }

  /* News Section */
  .news {
    padding: 4rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 2.5rem;
      }
    }

    &__header-left {
      // grouping wrapper
    }

    &__title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--c-text);
      margin: 0 0 0.25rem 0;

      @media (min-width: 768px) {
        font-size: 2.5rem;
      }
    }

    &__subtitle {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      margin: 0;
    }

    &__link {
      font-size: 0.85rem;
      color: var(--c-text-sub);
      text-decoration: none;
      transition: color 0.2s ease;
      white-space: nowrap;

      &:hover {
        color: var(--c-text);
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--c-border);
    }
  }

  .news-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    @media (min-width: 768px) {
      grid-template-columns: 110px 100px 1fr;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 0;
    }

    &:hover {
      opacity: 0.6;
    }

    &__date {
      font-size: 0.8rem;
      color: var(--c-text-light);
      font-weight: 500;

      @media (min-width: 768px) {
        font-size: 0.85rem;
      }
    }

    &__type {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--c-text-sub);
      background: var(--c-bg-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      font-weight: 500;
      width: fit-content;
      white-space: nowrap;

      @media (min-width: 768px) {
        font-size: 0.75rem;
      }
    }

    &__title {
      font-size: 0.9rem;
      color: var(--c-text);
      font-weight: 400;
      line-height: 1.5;

      @media (min-width: 768px) {
        font-size: 0.95rem;
      }
    }
  }
</style>
