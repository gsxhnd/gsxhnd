---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Contact from "../../components/Contact.astro";
import WorkCard from "../../components/WorkCard.astro";
import NewsCard from "../../components/NewsCard.astro";
import Hero from "../home/hero.astro";
import Partners from "../home/partners.astro";
import Service from "../home/service.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('site.title')}>
  <Hero />
  <Partners />
  <Service />

  <!-- Works Section -->
  <section class="works" id="works">
    <div class="works__container">
      <h2 class="section-title">{t('works.title')}</h2>
      <p class="works__subtitle">{t('works.subtitle')}</p>
      <div class="works__grid">
        <WorkCard
          tag="Website & App Development"
          title="E-commerce Platform Redesign"
          category="Fashion Brand"
          description="Complete overhaul of an online store for a major fashion retailer. Improved conversion rates by 40% through optimized UI/UX."
          link="/en/works/ec-platform-redesign"
        />
        <WorkCard
          tag="UI/UX Design"
          title="Corporate Branding"
          category="Tech Startup"
          description="Comprehensive brand refresh for a tech startup. Created logo design, style guide, and marketing materials."
          link="/en/works/corporate-branding"
        />
        <WorkCard
          tag="Mobile App Development"
          title="Mobile Banking App"
          category="Financial Institution"
          description="Secure and intuitive mobile banking app with over 100,000 active users. Provides seamless transaction experience."
          link="/en/works/mobile-banking-app"
        />
        <WorkCard
          tag="Digital Strategy"
          title="SaaS Dashboard Platform"
          category="Enterprise"
          description="Advanced analytics dashboard for enterprise clients. Implemented real-time data visualization and custom reporting features."
          link="/en/works/saas-dashboard-platform"
        />
      </div>
      <a href="/en/works/" class="works__link">{t('works.viewAll')}</a>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about__container">
      <h2 class="section-title">{t('about.title')}</h2>
      <p class="about__subtitle">{t('about.subtitle')}</p>
      <div class="about__content">
        <p>
          {t('about.description')}
        </p>
      </div>
      <a href="/en/about/" class="about__link">{t('about.viewMore')}</a>
    </div>
  </section>

  <!-- News Section -->
  <section class="news" id="news">
    <div class="news__container">
      <h2 class="section-title">{t('news.title')}</h2>
      <p class="news__subtitle">{t('news.subtitle')}</p>
      <div class="news__grid">
        <NewsCard
          date="2025.1.15"
          type="News"
          title="Markdown Style Guide - Examples of All Display Elements"
          link="/en/news/2025-01-15-markdown-guide"
        />
        <NewsCard
          date="2024.12.15"
          type="Press Release"
          title="Launch of AI-Powered Analytics Platform for Enterprise"
          link="/en/news/2024-12-15-ai-platform-release"
        />
        <NewsCard
          date="2024.11.28"
          type="News"
          title="Five Senior Developers Join Team to Strengthen Technical Capabilities"
          link="/en/news/2024-11-28-team-expansion"
        />
      </div>
      <a href="/en/news/" class="news__link">{t('news.viewAll')}</a>
    </div>
  </section>

  <Contact />
</Layout>

<style lang="scss">
  .works {
    background: var(--c-bg-secondary);
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 2rem;
      font-size: 0.95rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .about {
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        margin-bottom: 2rem;
      }
    }

    &__content {
      max-width: 700px;
      margin: 1.5rem auto;

      @media (min-width: 768px) {
        margin: 2rem auto;
      }

      p {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--c-text-sub);
        margin: 0;

        @media (min-width: 768px) {
          font-size: 1rem;
        }
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      margin-top: 1.5rem;
      transition: color 0.3s;

      @media (min-width: 768px) {
        margin-top: 2rem;
      }

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .news {
    background: var(--c-bg-secondary);
    padding: 3rem 1.5rem;

    @media (min-width: 768px) {
      padding: 5rem 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__subtitle {
      text-align: center;
      color: var(--c-text-sub);
      margin-bottom: 2rem;

      @media (min-width: 768px) {
        margin-bottom: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }
    }

    &__link {
      display: block;
      text-align: center;
      color: var(--c-primary);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;

      &:hover {
        color: var(--c-primary-light);
      }
    }
  }

  .section-title {
    text-align: center;
    font-size: 1.8rem;
    margin: 0 0 0.5rem 0;
    color: var(--c-text);

    @media (min-width: 768px) {
      font-size: 2.5rem;
    }
  }
</style>
